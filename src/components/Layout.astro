---
import '../styles/globals.css';
import LoadingScreen from './LoadingScreen.astro';

interface Props {
  title?: string;
}

const { title = 'Tristan Jay - AI Specialist' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Tristan Jay - AI Specialist Portfolio" />
    <title>{title}</title>
  </head>
  <body class="relative bg-gradient-to-b from-dark-primary via-dark-base to-dark-primary text-gray-200 overflow-x-hidden">
    <!-- Animated background elements -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden z-0">
      <!-- Floating particles -->
      <div
        class="absolute top-20 right-10 w-72 h-72 bg-neon-purple bg-opacity-10 rounded-full blur-3xl animate-float"
        style="animation-delay: 0s"
      ></div>
      <div
        class="absolute top-1/2 left-1/4 w-96 h-96 bg-neon-purple bg-opacity-10 rounded-full blur-3xl animate-float"
        style="animation-delay: 0.5s"
      ></div>
      <div
        class="absolute bottom-20 right-1/4 w-80 h-80 bg-neon-purple bg-opacity-10 rounded-full blur-3xl animate-float"
        style="animation-delay: 1s"
      ></div>

      <!-- Animated grid -->
      <div
        class="absolute inset-0 opacity-10"
        style="background-image: linear-gradient(rgba(255, 168, 210, 0.12) 1px, transparent 1px), linear-gradient(90deg, rgba(255, 179, 106, 0.1) 1px, transparent 1px); background-size: 50px 50px; animation: gridFlow 30s linear infinite"
      ></div>
    </div>
    <div class="ai-city-bg" aria-hidden="true"></div>
    <div class="ai-data-bg" aria-hidden="true"></div>
    <div class="ai-circuit-bg" aria-hidden="true"></div>
    <div class="ai-stream-lines" aria-hidden="true"></div>
    <canvas id="world3d" class="world-3d" aria-hidden="true"></canvas>
    <div class="ai-visibility-overlay" aria-hidden="true"></div>

    <!-- Loading screen -->
    <LoadingScreen />


    <!-- Main content -->
    <main class="relative z-10 ml-0">
      <slot />
    </main>

    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Zen+Dots&display=swap');
      :root {
        --color-primary: #00ff88;
        --color-secondary: #0096ff;
        --color-accent: #8a2be2;
        --color-dark: #0a0e1a;
        --color-darker: #050609;
        --color-text: #e0e0e0;
        --color-text-light: #b0b0b0;
        --hue-shift: 0deg;
      }

      body {
        font-family: 'Space Grotesk', system-ui, sans-serif;
      }

      @keyframes gridFlow {
        0% { background-position: 0 0; }
        100% { background-position: 100px 100px; }
      }

      @keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-20px); }
      }

      .ai-city-bg {
        position: fixed;
        inset: 0;
        background-image: url('/bg-anime-city.gif');
        background-size: cover;
        background-position: center;
        opacity: 0.35;
        filter: blur(0.4px) saturate(1.25) contrast(1.1) hue-rotate(var(--hue-shift));
        mix-blend-mode: screen;
        pointer-events: none;
        z-index: 0;
      }

      .ai-data-bg {
        position: fixed;
        inset: 0;
        background-image: url('/bg-data-stream.gif');
        background-size: cover;
        background-position: center;
        opacity: 0.02;
        mix-blend-mode: screen;
        filter: blur(0.4px) hue-rotate(var(--hue-shift));
        animation: dataDrift 20s linear infinite;
        pointer-events: none;
        z-index: 0;
      }

      .ai-circuit-bg {
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(90deg, rgba(255, 168, 210, 0.04) 1px, transparent 1px),
          linear-gradient(0deg, rgba(120, 190, 255, 0.035) 1px, transparent 1px);
        background-size: 120px 120px;
        opacity: 0.08;
        mix-blend-mode: screen;
        filter: blur(0.3px) hue-rotate(var(--hue-shift));
        animation: circuitFlow 18s linear infinite;
        pointer-events: none;
        z-index: 0;
      }

      .ai-stream-lines {
        position: fixed;
        inset: -10%;
        background-image:
          linear-gradient(120deg, rgba(255, 179, 106, 0.08) 2px, transparent 2px),
          linear-gradient(300deg, rgba(161, 227, 255, 0.06) 2px, transparent 2px);
        background-size: 280px 280px;
        opacity: 0.2;
        mix-blend-mode: screen;
        animation: streamSlide 16s linear infinite;
        pointer-events: none;
        z-index: 0;
      }

      .ai-visibility-overlay {
        position: fixed;
        inset: 0;
        background:
          radial-gradient(circle at 15% 20%, rgba(18, 12, 26, 0.5), transparent 55%),
          radial-gradient(circle at 80% 30%, rgba(18, 12, 26, 0.45), transparent 60%),
          linear-gradient(180deg, rgba(16, 10, 24, 0.6), rgba(16, 10, 24, 0.35));
        mix-blend-mode: multiply;
        pointer-events: none;
        z-index: 0;
      }

      .world-3d {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 0;
      }

      body::after {
        content: '';
        position: fixed;
        inset: 0;
        pointer-events: none;
        background: radial-gradient(circle at 50% 50%, rgba(18, 12, 26, 0.05), rgba(8, 8, 14, 0.35));
        animation: ambientDrift 14s ease-in-out infinite;
        mix-blend-mode: screen;
        z-index: 0;
      }

      @keyframes dataDrift {
        0% { background-position: 0 0; }
        100% { background-position: 0 -200px; }
      }

      @keyframes circuitFlow {
        0% { background-position: 0 0, 0 0; }
        100% { background-position: 240px 0, 0 240px; }
      }

      @keyframes streamSlide {
        0% { background-position: 0 0, 0 0; }
        100% { background-position: 280px -280px, -280px 280px; }
      }

      @keyframes ambientDrift {
        0%, 100% { transform: translate(0, 0); opacity: 0.45; }
        50% { transform: translate(-10px, 12px); opacity: 0.75; }
      }
    </style>
  </body>
</html>
