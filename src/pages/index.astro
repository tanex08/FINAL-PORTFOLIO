  }

  .game-controls {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .game-hints {
    list-style: none;
    padding: 0;
    margin: 0;
    color: #9aa0ad;
    font-size: 0.85rem;
    display: grid;
    gap: 0.35rem;
  }

  @media (max-width: 960px) {
    .game-shell {
      grid-template-columns: 1fr;
    }

    .game-stats {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      filter: none;
      transition: none;
    }

    .section-accent::after {
      transition: none;
      opacity: 0.4;
      transform: none;
    }
  }
</style>

<script>
  // Smooth scroll behavior is handled by CSS
  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener('click', function (e) {
      const href = this.getAttribute('href');
      if (href !== '#' && document.querySelector(href)) {
        e.preventDefault();
        document.querySelector(href).scrollIntoView({
          behavior: 'smooth',
        });
      }
    });
  });

  const revealItems = document.querySelectorAll('.reveal');
  revealItems.forEach((el) => {
    const delay = el.getAttribute('data-delay');
    if (delay) {
      el.style.transitionDelay = `${delay}ms`;
    }
  });

  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.18, rootMargin: '0px 0px -10% 0px' }
  );

  revealItems.forEach((el) => revealObserver.observe(el));

  const sections = document.querySelectorAll('.section-accent');
  const dividers = document.querySelectorAll('.section-divider');
  const sectionHueBase = 320;
  sections.forEach((section, idx) => {
    section.setAttribute('data-hue', String((sectionHueBase + idx * 18) % 360));
  });
  const sectionObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          if (entry.target.classList.contains('section-divider')) {
            entry.target.classList.add('is-active');
            return;
          }
          const accent = entry.target.getAttribute('data-accent');
          const hue = entry.target.getAttribute('data-hue');
          if (accent) {
            document.body.style.setProperty('--section-accent', accent);
          }
          if (hue) {
            document.body.style.setProperty('--hue-shift', `${hue}deg`);
          }
          sections.forEach((section) => section.classList.remove('is-active'));
          dividers.forEach((divider) => divider.classList.remove('is-active'));
          entry.target.classList.add('is-active');
          const scrollLogs = document.getElementById('scrollLogs');
          if (scrollLogs) {
            const label = entry.target.getAttribute('data-mission') || entry.target.id || 'Section';
            scrollLogs.textContent = `Section: ${label}`;
          }
        }
      });
    },
    { threshold: 0.5 }
  );

  sections.forEach((section) => sectionObserver.observe(section));
  dividers.forEach((divider) => sectionObserver.observe(divider));

  const personaButtons = document.querySelectorAll('.persona-btn');
  const heroSub = document.querySelector('.hero-sub');
  const heroRole = document.querySelector('.hero-role-sub');
  const personaCopy = {
    ai: { sub: 'AI Specialist', role: 'AI DEVELOPER' },
    fullstack: { sub: 'Full-Stack Dev', role: 'FULL-STACK DEV' },
    ml: { sub: 'ML Engineer', role: 'ML ENGINEER' }
  };
  personaButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      personaButtons.forEach((b) => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      const key = btn.getAttribute('data-persona');
      if (!key || !personaCopy[key]) return;
      document.body.setAttribute('data-persona', key);
      if (heroSub) heroSub.textContent = personaCopy[key].sub;
      if (heroRole) heroRole.textContent = personaCopy[key].role;
    });
  });

  const ambienceToggle = document.getElementById('ambienceToggle');
  const ambienceAudio = document.getElementById('cityAmbience');
  if (ambienceToggle && ambienceAudio) {
    ambienceToggle.addEventListener('click', async () => {
      try {
        if (ambienceAudio.paused) {
          await ambienceAudio.play();
          ambienceToggle.textContent = 'City Ambience On';
        } else {
          ambienceAudio.pause();
          ambienceToggle.textContent = 'City Ambience';
        }
      } catch {
        ambienceToggle.textContent = 'Enable Audio';
      }
    });
  }

  const filterButtons = document.querySelectorAll('.filter-btn');
  const projectCards = document.querySelectorAll('.project-card');
  filterButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterButtons.forEach((b) => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      const filter = btn.getAttribute('data-filter');
      projectCards.forEach((card) => {
        const cat = card.getAttribute('data-category');
        const show = filter === 'all' || cat === filter;
        card.style.display = show ? '' : 'none';
      });
    });
  });

  const caseModal = document.getElementById('caseModal');
  const caseClose = document.getElementById('caseClose');
  const caseTitle = document.getElementById('caseTitle');
  const caseProblem = document.getElementById('caseProblem');
  const caseApproach = document.getElementById('caseApproach');
  const caseResults = document.getElementById('caseResults');
  document.querySelectorAll('.case-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      caseTitle.textContent = btn.getAttribute('data-title') || 'Case Study';
      caseProblem.textContent = btn.getAttribute('data-problem') || '';
      caseApproach.textContent = btn.getAttribute('data-approach') || '';
      caseResults.textContent = btn.getAttribute('data-results') || '';
      caseModal?.classList.add('is-open');
      caseModal?.setAttribute('aria-hidden', 'false');
    });
  });
  caseClose?.addEventListener('click', () => {
    caseModal?.classList.remove('is-open');
    caseModal?.setAttribute('aria-hidden', 'true');
  });
  caseModal?.addEventListener('click', (e) => {
    if (e.target === caseModal || e.target?.classList?.contains('case-modal-backdrop')) {
      caseModal?.classList.remove('is-open');
      caseModal?.setAttribute('aria-hidden', 'true');
    }
  });

  const scrollObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        entry.target.classList.add('scroll-pop');
        setTimeout(() => entry.target.classList.remove('scroll-pop'), 900);
      });
    },
    { threshold: 0.3 }
  );

  sections.forEach((section) => scrollObserver.observe(section));

  const statObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const counter = entry.target;
        const target = Number(counter.getAttribute('data-count') || 0);
        let current = 0;
        const duration = 1200;
        const start = performance.now();
        const tick = (now) => {
          const progress = Math.min(1, (now - start) / duration);
          current = Math.floor(progress * target);
          counter.textContent = current.toString();
          if (progress < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
        statObserver.unobserve(counter);
      });
    },
    { threshold: 0.6 }
  );

  document.querySelectorAll('.hero-stat-value').forEach((el) => statObserver.observe(el));

  const outputStream = document.getElementById('outputStream');
  if (outputStream) {
    const streamLines = [
      'Inference: vision-core online...',
      'Routing: build pipeline stable...',
      'Signal: latency 62ms, uptime 99.9%...',
      'Deploy: release candidate green...'
    ];
    let lineIndex = 0;
    let charIndex = 0;
    const typeNext = () => {
      const line = streamLines[lineIndex];
      outputStream.textContent = line.slice(0, charIndex);
      charIndex += 1;
      if (charIndex > line.length) {
        charIndex = 0;
        lineIndex = (lineIndex + 1) % streamLines.length;
        setTimeout(typeNext, 800);
        return;
      }
      setTimeout(typeNext, 40);
    };
    typeNext();
  }

  const cards = document.querySelectorAll('.card-tilt');
  cards.forEach((card) => {
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const rx = ((y / rect.height) - 0.5) * 8;
      const ry = ((x / rect.width) - 0.5) * -8;
      card.style.transform = `rotateX(${rx}deg) rotateY(${ry}deg)`;
      card.style.setProperty('--spot-x', `${(x / rect.width) * 100}%`);
      card.style.setProperty('--spot-y', `${(y / rect.height) * 100}%`);
    });
    card.addEventListener('mouseleave', () => {
      card.style.transform = 'rotateX(0deg) rotateY(0deg)';
    });
  });

  const resumeFab = document.getElementById('resumeFab');
  const resumeModal = document.getElementById('resumeModal');
  const resumeClose = document.getElementById('resumeClose');
  resumeFab?.addEventListener('click', () => {
    resumeModal?.classList.add('is-open');
    resumeModal?.setAttribute('aria-hidden', 'false');
  });
  resumeClose?.addEventListener('click', () => {
    resumeModal?.classList.remove('is-open');
    resumeModal?.setAttribute('aria-hidden', 'true');
  });
  resumeModal?.addEventListener('click', (e) => {
    if (e.target === resumeModal || e.target?.classList?.contains('resume-modal-backdrop')) {
      resumeModal?.classList.remove('is-open');
      resumeModal?.setAttribute('aria-hidden', 'true');
    }
  });

  const constellationCanvas = document.getElementById('constellationCanvas');
  const constellationCursor = document.getElementById('constellationCursor');
  const heroCanvas = document.getElementById('hero3d');
  const globeStage = document.querySelector('.globe-stage');
  let mouseX = window.innerWidth / 2;
  let mouseY = window.innerHeight / 2;
  let lastMouseX = mouseX;
  let lastMouseY = mouseY;
  let constellationActive = false;

  if (constellationCanvas) {
    const ctx = constellationCanvas.getContext('2d');
    const stars = [];
    const starCount = 70;
    const linkDistance = 130;

    const resizeCanvas = () => {
      const dpr = window.devicePixelRatio || 1;
      constellationCanvas.width = window.innerWidth * dpr;
      constellationCanvas.height = window.innerHeight * dpr;
      constellationCanvas.style.width = `${window.innerWidth}px`;
      constellationCanvas.style.height = `${window.innerHeight}px`;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };

    const createStars = () => {
      stars.length = 0;
      for (let i = 0; i < starCount; i += 1) {
        stars.push({
          x: Math.random() * window.innerWidth,
          y: Math.random() * window.innerHeight,
          r: Math.random() * 1.8 + 0.6,
          vx: (Math.random() - 0.5) * 0.2,
          vy: (Math.random() - 0.5) * 0.2,
        });
      }
    };

    const draw = () => {
      ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);
      ctx.fillStyle = 'rgba(255, 168, 210, 0.6)';

      stars.forEach((star) => {
        star.x += star.vx;
        star.y += star.vy;
        if (star.x < 0 || star.x > window.innerWidth) star.vx *= -1;
        if (star.y < 0 || star.y > window.innerHeight) star.vy *= -1;
        ctx.beginPath();
        ctx.arc(star.x, star.y, star.r, 0, Math.PI * 2);
        ctx.fill();
      });

      ctx.strokeStyle = 'rgba(255, 168, 210, 0.12)';
      for (let i = 0; i < stars.length; i += 1) {
        for (let j = i + 1; j < stars.length; j += 1) {
          const dx = stars[i].x - stars[j].x;
          const dy = stars[i].y - stars[j].y;
          const dist = Math.hypot(dx, dy);
          if (dist < linkDistance) {
            ctx.globalAlpha = 1 - dist / linkDistance;
            ctx.beginPath();
            ctx.moveTo(stars[i].x, stars[i].y);
            ctx.lineTo(stars[j].x, stars[j].y);
            ctx.stroke();
          }
        }
      }

      if (constellationActive) {
        ctx.strokeStyle = 'rgba(255, 179, 106, 0.45)';
        stars.forEach((star) => {
          const dx = star.x - mouseX;
          const dy = star.y - mouseY;
          const dist = Math.hypot(dx, dy);
          if (dist < linkDistance) {
            ctx.globalAlpha = 1 - dist / linkDistance;
            ctx.beginPath();
            ctx.moveTo(star.x, star.y);
            ctx.lineTo(mouseX, mouseY);
            ctx.stroke();
          }
        });
      }

      ctx.globalAlpha = 1;
      requestAnimationFrame(draw);
    };

    resizeCanvas();
    createStars();
    requestAnimationFrame(draw);

    window.addEventListener('resize', () => {
      resizeCanvas();
      createStars();
    });
  }

  const spawnTrail = (x, y, intensity) => {
    if (intensity < 8) return;
    const dot = document.createElement('div');
    dot.className = 'cursor-trail';
    dot.style.left = `${x - 4}px`;
    dot.style.top = `${y - 4}px`;
    dot.style.opacity = Math.min(0.9, 0.4 + intensity / 35).toString();
    dot.style.transform = `scale(${Math.min(1.4, 0.6 + intensity / 40)})`;
    document.body.appendChild(dot);
    setTimeout(() => {
      dot.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
      dot.style.opacity = '0';
      dot.style.transform = 'scale(0.2)';
    }, 10);
    setTimeout(() => dot.remove(), 650);
  };

  window.addEventListener('mousemove', (e) => {
    mouseX = e.clientX;
    mouseY = e.clientY;
    const speed = Math.hypot(mouseX - lastMouseX, mouseY - lastMouseY);
    lastMouseX = mouseX;
    lastMouseY = mouseY;
    if (constellationCursor) {
      constellationCursor.style.transform = `translate(${mouseX}px, ${mouseY}px) translate(-50%, -50%) translate(4px, 0px)`;
    }
    spawnTrail(mouseX, mouseY, speed);
  });

  document.querySelectorAll('.section-block').forEach((section) => {
    section.addEventListener('mouseenter', () => {
      constellationActive = true;
    });
    section.addEventListener('mouseleave', () => {
      constellationActive = false;
    });
  });

  const parallax = (e) => {
    const x = (e.clientX / window.innerWidth - 0.5) * 8;
    const y = (e.clientY / window.innerHeight - 0.5) * 8;
    if (globeStage) {
      globeStage.style.transform = `translate(${x * 0.7}px, ${y * 0.7}px)`;
    }
  };

  window.addEventListener('mousemove', parallax);

  // 3D hero is initialized in the module script below.

  const canvas = document.getElementById('gameCanvasModal');
  if (canvas) {
    const ctx = canvas.getContext('2d');
    const scoreEl = document.getElementById('gameScoreModal');
    const bestEl = document.getElementById('gameBestModal');
    const livesEl = document.getElementById('gameLivesModal');
    const startBtn = document.getElementById('startGameBtnModal');
    const pauseBtn = document.getElementById('pauseGameBtnModal');
    const resetBtn = document.getElementById('resetGameBtnModal');

    const WIDTH = 900;
    const HEIGHT = 520;
    const dpr = window.devicePixelRatio || 1;
    canvas.width = WIDTH * dpr;
    canvas.height = HEIGHT * dpr;
    ctx.scale(dpr, dpr);

    const state = {
      running: false,
      paused: false,
      score: 0,
      best: Number(localStorage.getItem('astroBest') || 0),
      lives: 3,
      lastTime: 0,
      spawnTimer: 0,
      spawnInterval: 900,
      speedBoost: false,
      pointerActive: false,
      pointerX: WIDTH / 2,
      pointerY: HEIGHT / 2,
    };

    const player = {
      x: WIDTH / 2,
      y: HEIGHT * 0.75,
      r: 14,
      speed: 260,
    };

    const enemies = [];
    const particles = [];
    const keys = new Set();

    bestEl.textContent = state.best;
    livesEl.textContent = state.lives;

    function resetGame() {
      state.score = 0;
      state.lives = 3;
      state.spawnInterval = 900;
      state.spawnTimer = 0;
      enemies.length = 0;
      particles.length = 0;
      player.x = WIDTH / 2;
      player.y = HEIGHT * 0.75;
      livesEl.textContent = state.lives;
      scoreEl.textContent = state.score;
    }

    function spawnEnemy() {
      const edge = Math.floor(Math.random() * 4);
      const size = 10 + Math.random() * 16;
      let x = 0;
      let y = 0;
      if (edge === 0) {
        x = Math.random() * WIDTH;
        y = -20;
      } else if (edge === 1) {
        x = WIDTH + 20;
        y = Math.random() * HEIGHT;
      } else if (edge === 2) {
        x = Math.random() * WIDTH;
        y = HEIGHT + 20;
      } else {
        x = -20;
        y = Math.random() * HEIGHT;
      }
      enemies.push({
        x,
        y,
        r: size,
        speed: 60 + Math.random() * 100,
      });
    }

    function spawnParticles(x, y, count) {
      for (let i = 0; i < count; i += 1) {
        particles.push({
          x,
          y,
          vx: (Math.random() - 0.5) * 200,
          vy: (Math.random() - 0.5) * 200,
          life: 0.6 + Math.random() * 0.6,
        });
      }
    }

    function update(dt) {
      const speed = player.speed * (state.speedBoost ? 1.6 : 1);
      let vx = 0;
      let vy = 0;

      if (state.pointerActive) {
        const dx = state.pointerX - player.x;
        const dy = state.pointerY - player.y;
        const dist = Math.hypot(dx, dy) || 1;
        vx = (dx / dist) * speed;
        vy = (dy / dist) * speed;
        if (dist < 6) {
          vx = 0;
          vy = 0;
        }
      } else {
        if (keys.has('ArrowLeft') || keys.has('a')) vx -= speed;
        if (keys.has('ArrowRight') || keys.has('d')) vx += speed;
        if (keys.has('ArrowUp') || keys.has('w')) vy -= speed;
        if (keys.has('ArrowDown') || keys.has('s')) vy += speed;
      }

      player.x = Math.max(player.r, Math.min(WIDTH - player.r, player.x + vx * dt));
      player.y = Math.max(player.r, Math.min(HEIGHT - player.r, player.y + vy * dt));

      state.spawnTimer += dt * 1000;
      if (state.spawnTimer > state.spawnInterval) {
        state.spawnTimer = 0;
        spawnEnemy();
        state.spawnInterval = Math.max(380, state.spawnInterval - 6);
      }

      for (let i = enemies.length - 1; i >= 0; i -= 1) {
        const enemy = enemies[i];
        const dx = player.x - enemy.x;
        const dy = player.y - enemy.y;
        const dist = Math.hypot(dx, dy) || 1;
        enemy.x += (dx / dist) * enemy.speed * dt;
        enemy.y += (dy / dist) * enemy.speed * dt;

        if (dist < player.r + enemy.r) {
          enemies.splice(i, 1);
          state.lives -= 1;
          livesEl.textContent = state.lives;
          spawnParticles(player.x, player.y, 16);
          if (state.lives <= 0) {
            state.running = false;
            state.paused = false;
            pauseBtn.textContent = 'Pause';
          }
        }
      }

      for (let i = particles.length - 1; i >= 0; i -= 1) {
        const p = particles[i];
        p.life -= dt;
        p.x += p.vx * dt;
        p.y += p.vy * dt;
        if (p.life <= 0) particles.splice(i, 1);
      }

      if (state.running) {
        state.score += Math.floor(dt * 120);
        scoreEl.textContent = state.score;
        if (state.score > state.best) {
          state.best = state.score;
          bestEl.textContent = state.best;
          localStorage.setItem('astroBest', state.best);
        }
      }
    }

    function draw() {
      ctx.clearRect(0, 0, WIDTH, HEIGHT);
      ctx.save();

      const gradient = ctx.createRadialGradient(player.x, player.y, 0, player.x, player.y, 220);
      gradient.addColorStop(0, 'rgba(0, 255, 136, 0.12)');
      gradient.addColorStop(1, 'rgba(0, 0, 0, 0)');
      ctx.fillStyle = gradient;
      ctx.fillRect(0, 0, WIDTH, HEIGHT);

      enemies.forEach((enemy) => {
        ctx.beginPath();
        ctx.fillStyle = 'rgba(0, 150, 255, 0.6)';
        ctx.arc(enemy.x, enemy.y, enemy.r, 0, Math.PI * 2);
        ctx.fill();
      });

      particles.forEach((p) => {
        ctx.beginPath();
        ctx.fillStyle = 'rgba(0, 255, 136, 0.7)';
        ctx.arc(p.x, p.y, 2.2, 0, Math.PI * 2);
        ctx.fill();
      });

      ctx.beginPath();
      ctx.fillStyle = 'rgba(0, 255, 136, 0.9)';
      ctx.moveTo(player.x, player.y - player.r);
      ctx.lineTo(player.x - player.r, player.y + player.r);
      ctx.lineTo(player.x + player.r, player.y + player.r);
      ctx.closePath();
      ctx.fill();

      ctx.restore();
    }

    function loop(timestamp) {
      if (!state.lastTime) state.lastTime = timestamp;
      const dt = Math.min(0.033, (timestamp - state.lastTime) / 1000);
      state.lastTime = timestamp;

      if (state.running && !state.paused) {
        update(dt);
      }
      draw();
      requestAnimationFrame(loop);
    }

    function startGame() {
      if (!state.running) {
        resetGame();
        state.running = true;
      }
    }

    function togglePause() {
      if (!state.running) return;
      state.paused = !state.paused;
      pauseBtn.textContent = state.paused ? 'Resume' : 'Pause';
    }

    function stopGame() {
      state.running = false;
      state.paused = false;
      pauseBtn.textContent = 'Pause';
      resetGame();
    }

    startBtn?.addEventListener('click', startGame);
    pauseBtn?.addEventListener('click', togglePause);
    resetBtn?.addEventListener('click', stopGame);

    window.addEventListener('keydown', (e) => {
      if (['ArrowLeft', 'ArrowRight', 'ArrowUp', 'ArrowDown'].includes(e.key)) e.preventDefault();
      if (e.key === 'Shift') state.speedBoost = true;
      keys.add(e.key.toLowerCase());
      if (e.key === ' ') {
        startGame();
      }
    });

    window.addEventListener('keyup', (e) => {
      if (e.key === 'Shift') state.speedBoost = false;
      keys.delete(e.key.toLowerCase());
    });

    canvas.addEventListener('pointerdown', (e) => {
      state.pointerActive = true;
      const rect = canvas.getBoundingClientRect();
      state.pointerX = ((e.clientX - rect.left) / rect.width) * WIDTH;
      state.pointerY = ((e.clientY - rect.top) / rect.height) * HEIGHT;
      startGame();
    });

    canvas.addEventListener('pointermove', (e) => {
      if (!state.pointerActive) return;
      const rect = canvas.getBoundingClientRect();
      state.pointerX = ((e.clientX - rect.left) / rect.width) * WIDTH;
      state.pointerY = ((e.clientY - rect.top) / rect.height) * HEIGHT;
    });

    window.addEventListener('pointerup', () => {
      state.pointerActive = false;
    });

    requestAnimationFrame(loop);
  }

  const chatFab = document.getElementById('chatFab');
  const chatModal = document.getElementById('chatModal');
  const chatClose = document.getElementById('chatClose');
  const chatForm = document.getElementById('chatForm');
  const chatInput = document.getElementById('chatInput');
  const chatMessages = document.getElementById('chatMessages');

  const appendChat = (text, role = 'bot') => {
    if (!chatMessages) return;
    const bubble = document.createElement('div');
    bubble.className = `chat-bubble ${role === 'user' ? 'user' : 'bot'}`;
    bubble.textContent = text;
    chatMessages.appendChild(bubble);
    chatMessages.scrollTop = chatMessages.scrollHeight;
  };

  const fetchReply = async (message) => {
    const body = new URLSearchParams({ message }).toString();
    const res = await fetch(`/api/chat?message=${encodeURIComponent(message)}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body
    });
    if (!res.ok) {
      const err = await res.json().catch(() => ({}));
      const detail = err?.detail ? ` (${err.detail})` : '';
      if (res.status === 429) {
        return { reply: null, quota: true };
      }
      throw new Error((err?.error || 'Chat API error') + detail);
    }
    const data = await res.json();
    return { reply: data?.reply || 'I had trouble generating a response. Try again.', quota: false };
  };

  const pickFallbackReply = (message) => {
    const msg = message.toLowerCase();
    if (msg.includes('project')) {
      return "I build AI + full-stack projects like CV systems, ticketing automation, and smart web apps. Want to see a specific project?";
    }
    if (msg.includes('skill') || msg.includes('stack') || msg.includes('tech')) {
      return "My core stack: React, Astro, Tailwind, Node.js, Python, and Docker. I also work with ML/AI and computer vision.";
    }
    if (msg.includes('contact') || msg.includes('email')) {
      return "You can reach me at gaid.tristan123@gmail.com or @Tanex112 on Discord.";
    }
    if (msg.includes('hire') || msg.includes('available')) {
      return "I'm open to freelance and collaboration. Tell me the role or project scope and I can share availability.";
    }
    return "Tell me what you'd like to explore: projects, skills, or availability.";
  };

  const openChat = () => {
    chatModal?.classList.add('is-open');
    chatModal?.setAttribute('aria-hidden', 'false');
    if (chatMessages && chatMessages.childElementCount === 0) {
      appendChat("Hi! I'm Tristan's AI assistant. Ask me about projects, skills, or contact info.");
    }
    setTimeout(() => chatInput?.focus(), 50);
  };

  const closeChat = () => {
    chatModal?.classList.remove('is-open');
    chatModal?.setAttribute('aria-hidden', 'true');
  };

  chatFab?.addEventListener('click', openChat);
  chatClose?.addEventListener('click', closeChat);
  chatModal?.addEventListener('click', (e) => {
    if (e.target === chatModal || e.target?.classList?.contains('chat-modal-backdrop')) {
      closeChat();
    }
  });

  chatForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const text = (chatInput?.value || '').trim();
    if (!text) return;
    appendChat(text, 'user');
    if (chatInput) chatInput.value = '';
    const typing = document.createElement('div');
    typing.className = 'chat-bubble bot';
    typing.textContent = '...';
    chatMessages?.appendChild(typing);
    chatMessages.scrollTop = chatMessages.scrollHeight;
    try {
      const result = await fetchReply(text);
      typing.remove();
      if (result?.quota) {
        appendChat(pickFallbackReply(text) + ' (AI quota reached — using offline mode.)', 'bot');
      } else {
        appendChat(result.reply, 'bot');
      }
    } catch (err) {
      typing.remove();
      appendChat('Chat service is unavailable right now. Please try again shortly.', 'bot');
      console.error(err);
    }
  });

  const gameFab = document.getElementById('gameFab');
  const gameModal = document.getElementById('gameModal');
  const gameClose = document.getElementById('gameClose');

  gameFab?.addEventListener('click', () => {
    gameModal?.classList.add('is-open');
    gameModal?.setAttribute('aria-hidden', 'false');
  });

  gameClose?.addEventListener('click', () => {
    gameModal?.classList.remove('is-open');
    gameModal?.setAttribute('aria-hidden', 'true');
  });

  gameModal?.addEventListener('click', (e) => {
    if (e.target === gameModal || e.target?.classList?.contains('game-modal-backdrop')) {
      gameModal?.classList.remove('is-open');
      gameModal?.setAttribute('aria-hidden', 'true');
    }
  });
</script>

<script is:inline type="module">
  import * as THREE from 'https://esm.sh/three@0.161.0';
  import { GLTFLoader } from 'https://esm.sh/three@0.161.0/examples/jsm/loaders/GLTFLoader.js';
  import { DRACOLoader } from 'https://esm.sh/three@0.161.0/examples/jsm/loaders/DRACOLoader.js';

  const canvas = document.getElementById('hero3d');
  const fallback = document.getElementById('hero3dFallback');
  if (canvas) {
    console.log('[hero3d] init');
    const scene = new THREE.Scene();
    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.1;
    renderer.physicallyCorrectLights = true;
    const resizeRenderer = () => {
      const rect = canvas.getBoundingClientRect();
      if (rect.width === 0 || rect.height === 0) return;
      renderer.setSize(rect.width, rect.height, false);
      camera.aspect = rect.width / rect.height;
      camera.updateProjectionMatrix();
    };

    const camera = new THREE.PerspectiveCamera(32, 1, 0.1, 100);
    camera.position.set(0, 1.35, 2.1);
    camera.lookAt(0, 1.05, 0);

    const ambient = new THREE.AmbientLight(0x8aa0ff, 0.55);
    scene.add(ambient);

    const keyLight = new THREE.DirectionalLight(0xffffff, 1.4);
    keyLight.position.set(2, 2, 3);
    scene.add(keyLight);

    const rim = new THREE.PointLight(0x8a2be2, 2.0, 10);
    rim.position.set(-2, 1, -2);
    scene.add(rim);

    const fill = new THREE.PointLight(0x00ff88, 1.1, 6);
    fill.position.set(1.5, -1, 2);
    scene.add(fill);

    const hemi = new THREE.HemisphereLight(0xbfd6ff, 0x202430, 0.45);
    scene.add(hemi);

    const loader = new GLTFLoader();
    const dracoLoader = new DRACOLoader();
    dracoLoader.setDecoderPath('https://www.gstatic.com/draco/v1/decoders/');
    loader.setDRACOLoader(dracoLoader);
    const modelUrl = '/hero.glb';
    let model = null;
    let baseY = -0.4;

    loader.load(
      modelUrl,
      (gltf) => {
        console.log('[hero3d] model loaded');
        if (fallback) fallback.classList.remove('is-visible');
        model = gltf.scene;
        model.traverse((child) => {
          if (child.isMesh && child.material) {
            const mats = Array.isArray(child.material) ? child.material : [child.material];
            mats.forEach((mat) => {
              if (mat.map) {
                mat.map.colorSpace = THREE.SRGBColorSpace;
              }
              mat.roughness = mat.roughness ?? 0.6;
              mat.metalness = mat.metalness ?? 0.1;
              mat.needsUpdate = true;
            });
            child.castShadow = false;
            child.receiveShadow = false;
          }
        });
        const box = new THREE.Box3().setFromObject(model);
        const size = new THREE.Vector3();
        const center = new THREE.Vector3();
        box.getSize(size);
        box.getCenter(center);
        console.log('[hero3d] model bounds', size);
        model.position.sub(center);

        const targetHeight = 2.2;
        const scale = targetHeight / Math.max(size.y, 0.0001);
        model.scale.setScalar(scale);
        model.position.set(0, 0, 0);
        scene.add(model);

        const scaledBox = new THREE.Box3().setFromObject(model);
        const scaledCenter = new THREE.Vector3();
        scaledBox.getCenter(scaledCenter);
        model.position.sub(scaledCenter);

        const fitBox = new THREE.Box3().setFromObject(model);
        const sphere = new THREE.Sphere();
        fitBox.getBoundingSphere(sphere);
        const radius = Math.max(sphere.radius, 0.0001);

        const fov = (camera.fov * Math.PI) / 180;
        const cameraZ = radius / Math.tan(fov / 2) * 0.8;
        const lookY = radius * 0.2;
        camera.position.set(0, lookY, cameraZ);
        camera.lookAt(0, lookY, 0);
        renderer.localClippingEnabled = false;
        resizeRenderer();
        // Debug helper removed.
      },
      undefined,
      (err) => {
        console.error('[hero3d] model failed', err);
        if (fallback) fallback.classList.add('is-visible');
      }
    );

    let targetX = 0;
    let targetY = 0;

    const onMove = (e) => {
      const rect = canvas.getBoundingClientRect();
      const nx = (e.clientX - rect.left) / rect.width - 0.5;
      const ny = (e.clientY - rect.top) / rect.height - 0.5;
      targetX = Math.max(-0.5, Math.min(0.5, nx));
      targetY = Math.max(-0.5, Math.min(0.5, ny));
    };

    window.addEventListener('mousemove', onMove);

    window.addEventListener('resize', resizeRenderer);
    resizeRenderer();

    const clock = new THREE.Clock();
    const animate = () => {
      const t = clock.getElapsedTime();
      if (model) {
        model.rotation.y = targetX * 0.8;
        model.rotation.x = -targetY * 0.5;
        model.position.y = baseY + Math.sin(t * 1.4) * 0.03;
      }
      renderer.render(scene, camera);
      requestAnimationFrame(animate);
    };
    animate();
  }

  const worldCanvas = document.getElementById('world3d');
  if (worldCanvas) {
    const scene = new THREE.Scene();
    const renderer = new THREE.WebGLRenderer({ canvas: worldCanvas, alpha: true, antialias: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 1.5));
    renderer.setSize(window.innerWidth, window.innerHeight, false);
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 0.9;
    renderer.setClearColor(0x000000, 0);

    const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 200);
    const baseCam = new THREE.Vector3(0, 1.2, 8);
    camera.position.copy(baseCam);

    const ambient = new THREE.AmbientLight(0xffffff, 0.2);
    scene.add(ambient);

    const starGeo = new THREE.BufferGeometry();
    const starCount = 220;
    const starPos = new Float32Array(starCount * 3);
    for (let i = 0; i < starCount; i += 1) {
      starPos[i * 3] = (Math.random() - 0.5) * 60;
      starPos[i * 3 + 1] = Math.random() * 10;
      starPos[i * 3 + 2] = -10 - Math.random() * 60;
    }
    starGeo.setAttribute('position', new THREE.BufferAttribute(starPos, 3));
    const starMat = new THREE.PointsMaterial({ color: 0xffd0e6, size: 0.06, opacity: 0.45, transparent: true });
    const stars = new THREE.Points(starGeo, starMat);
    scene.add(stars);

    const lineMat = new THREE.LineBasicMaterial({ color: 0xffb36a, transparent: true, opacity: 0.12 });
    const lineGeo = new THREE.BufferGeometry();
    const linePoints = [];
    for (let i = 0; i < 30; i += 1) {
      linePoints.push(new THREE.Vector3((Math.random() - 0.5) * 20, Math.random() * 6, -6 - Math.random() * 18));
      linePoints.push(new THREE.Vector3((Math.random() - 0.5) * 20, Math.random() * 6, -6 - Math.random() * 18));
    }
    lineGeo.setFromPoints(linePoints);
    const lines = new THREE.LineSegments(lineGeo, lineMat);
    scene.add(lines);


    const scrollState = { t: 0 };
    const mouse = { x: 0, y: 0 };

    window.addEventListener('mousemove', (e) => {
      mouse.x = (e.clientX / window.innerWidth - 0.5) * 2;
      mouse.y = (e.clientY / window.innerHeight - 0.5) * 2;
    });

    const onResize = () => {
      renderer.setSize(window.innerWidth, window.innerHeight, false);
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
    };
    window.addEventListener('resize', onResize);

    const clock = new THREE.Clock();
    const animate = () => {
      const dt = clock.getDelta();
      const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
      scrollState.t = maxScroll > 0 ? window.scrollY / maxScroll : 0;
      const drift = Math.sin(clock.elapsedTime * 0.35) * 0.1;

      camera.position.x = mouse.x * 0.45;
      camera.position.y = baseCam.y + scrollState.t * 0.9 + mouse.y * 0.25;
      camera.position.z = baseCam.z - scrollState.t * 2.1 + drift;
      camera.lookAt(0, 0, -6);

      stars.rotation.y += dt * 0.01;
      lines.rotation.z = Math.sin(clock.elapsedTime * 0.2) * 0.02;


      renderer.render(scene, camera);
      requestAnimationFrame(animate);
    };
    animate();
  }

  const globeCanvas = document.getElementById('globeCanvas');
  if (globeCanvas) {
    const scene = new THREE.Scene();
    const renderer = new THREE.WebGLRenderer({ canvas: globeCanvas, alpha: true, antialias: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));

    const size = () => {
      const rect = globeCanvas.getBoundingClientRect();
      renderer.setSize(rect.width, rect.height, false);
      camera.aspect = rect.width / rect.height;
      camera.updateProjectionMatrix();
    };

    const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 100);
    camera.position.set(0, 0, 6);

    const ambient = new THREE.AmbientLight(0xffffff, 0.6);
    scene.add(ambient);
    const rim = new THREE.PointLight(0xffb36a, 1.0, 20);
    rim.position.set(4, 2, 6);
    scene.add(rim);

    const points = 1200;
    const positions = new Float32Array(points * 3);
    for (let i = 0; i < points; i += 1) {
      const u = Math.random();
      const v = Math.random();
      const theta = 2 * Math.PI * u;
      const phi = Math.acos(2 * v - 1);
      const r = 2.2;
      positions[i * 3] = r * Math.sin(phi) * Math.cos(theta);
      positions[i * 3 + 1] = r * Math.sin(phi) * Math.sin(theta);
      positions[i * 3 + 2] = r * Math.cos(phi);
    }

    const geo = new THREE.BufferGeometry();
    geo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
    const mat = new THREE.PointsMaterial({ color: 0xffd0e6, size: 0.045, opacity: 0.9, transparent: true });
    const globe = new THREE.Points(geo, mat);
    scene.add(globe);

    const hotspotButtons = Array.from(document.querySelectorAll('.globe-btn'));
    const hotspotVectors = [
      new THREE.Vector3(1, 0.3, 1),
      new THREE.Vector3(-1, 0.3, 1),
      new THREE.Vector3(0, 0.9, 1),
      new THREE.Vector3(0.9, -0.1, 1),
      new THREE.Vector3(-0.9, -0.1, 1),
      new THREE.Vector3(0, -0.95, 1),
      new THREE.Vector3(0.7, -0.6, 1),
      new THREE.Vector3(-0.7, -0.6, 1),
      new THREE.Vector3(0.3, 0.9, 1),
      new THREE.Vector3(-0.3, 0.9, 1),
    ].map((v) => v.normalize().multiplyScalar(2.6));

    const modal = document.getElementById('sectionModal');
    const modalContent = document.getElementById('sectionModalContent');
    const modalClose = document.getElementById('sectionModalClose');

    const openModal = (target) => {
      const section = document.querySelector(target);
      if (!section || !modal || !modalContent) return;
      modalContent.innerHTML = '';
      const wrapper = document.createElement('div');
      wrapper.className = 'modal-section-wrapper';
      const clone = section.cloneNode(true);
      clone.classList.remove('locked-section');
      clone.classList.add('is-unlocked');
      clone.style.display = 'block';
      clone.style.opacity = '1';
      clone.style.transform = 'none';
      clone.querySelectorAll('.absolute.inset-0.-z-10').forEach((el) => el.remove());
      clone.querySelectorAll('.reveal').forEach((el) => {
        el.classList.add('is-visible');
        el.style.opacity = '1';
        el.style.transform = 'none';
        el.style.filter = 'none';
      });
      wrapper.appendChild(clone);
      modalContent.appendChild(wrapper);
      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
    };

    const closeModal = () => {
      modal?.classList.remove('is-open');
      modal?.setAttribute('aria-hidden', 'true');
      modalContent.innerHTML = '';
    };

    modalClose?.addEventListener('click', closeModal);
    modal?.addEventListener('click', (e) => {
      if (e.target === modal || e.target?.classList?.contains('section-modal-backdrop')) {
        closeModal();
      }
    });

    hotspotButtons.forEach((btn, idx) => {
      btn.addEventListener('click', () => {
        const target = btn.getAttribute('data-target');
        if (target) openModal(target);
      });
      btn.dataset.index = String(idx);
    });

    let dragging = false;
    let lastX = 0;
    let lastY = 0;
    globeCanvas.addEventListener('pointerdown', (e) => {
      dragging = true;
      lastX = e.clientX;
      lastY = e.clientY;
    });
    window.addEventListener('pointerup', () => {
      dragging = false;
    });
    window.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      const dx = (e.clientX - lastX) * 0.005;
      const dy = (e.clientY - lastY) * 0.005;
      globe.rotation.y += dx;
      globe.rotation.x += dy;
      lastX = e.clientX;
      lastY = e.clientY;
    });

    size();
    window.addEventListener('resize', size);

    const clock = new THREE.Clock();
    const animate = () => {
      const dt = clock.getDelta();
      if (!dragging) {
        globe.rotation.y += dt * 0.2;
      }

      hotspotButtons.forEach((btn, idx) => {
        const local = hotspotVectors[idx] ? hotspotVectors[idx].clone() : new THREE.Vector3(0, 0, 2.2);
        local.applyEuler(globe.rotation);
        const pos = local.clone();
        const projected = pos.clone().project(camera);
        const rect = globeCanvas.getBoundingClientRect();
        const x = (projected.x * 0.5 + 0.5) * rect.width;
        const y = (-projected.y * 0.5 + 0.5) * rect.height;
        const visible = projected.z < 1 && local.z > 0;
        btn.style.left = `${x}px`;
        btn.style.top = `${y}px`;
        btn.classList.toggle('is-visible', visible);
      });

      renderer.render(scene, camera);
      requestAnimationFrame(animate);
    };
    animate();
  }
</script>

