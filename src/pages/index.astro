  .constellation-cursor {
    position: fixed;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 2px solid rgba(255, 168, 210, 0.9);
    background: radial-gradient(circle, rgba(255, 168, 210, 0.8), rgba(255, 168, 210, 0) 65%);
    box-shadow: 0 0 18px rgba(255, 168, 210, 0.7), 0 0 40px rgba(255, 179, 106, 0.35);
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 120;
  }

  .constellation-cursor::after {
    content: '';
    position: absolute;
    inset: 50% auto auto 50%;
    width: 4px;
    height: 4px;
    background: #ffd0e6;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    box-shadow: 0 0 6px rgba(255, 208, 230, 0.9);
