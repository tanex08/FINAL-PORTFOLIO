  #projects .card-glass::before {
    content: '';
    position: absolute;
    inset: -40% -30%;
    background: linear-gradient(120deg, transparent 35%, rgba(161, 227, 255, 0.25) 55%, transparent 70%);
    opacity: 0;
    transform: translateX(-40%);
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

