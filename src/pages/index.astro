<style>
  :global(body) {
    --section-accent: rgba(0, 255, 136, 0.2);
  }

  .section-block {
    position: relative;
    isolation: isolate;
    scroll-margin-top: 80px;
    overflow: hidden;
  }

  .section-block::before {
    content: '';
    position: absolute;
    inset: 12px;
    border-radius: 28px;
    border: 1px solid rgba(255, 168, 210, 0.15);
    box-shadow: 0 0 30px rgba(255, 140, 180, 0.12);
    opacity: 0.5;
    pointer-events: none;
    transition: box-shadow 0.6s ease, opacity 0.6s ease;
  }

  .section-block::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      120deg,
      rgba(255, 179, 106, 0.06) 0px,
      rgba(255, 179, 106, 0.06) 1px,
      transparent 1px,
      transparent 120px
    );
    opacity: 0.35;
    pointer-events: none;
    mix-blend-mode: screen;
  }

  .section-divider {
    position: relative;
    height: 1px;
    margin: 0 auto 2.5rem;
    width: min(720px, 90vw);
    background: linear-gradient(90deg, transparent, rgba(255, 179, 106, 0.6), transparent);
    box-shadow: 0 0 18px rgba(255, 179, 106, 0.35);
    opacity: 0.3;
  }

  .section-divider.is-active {
    opacity: 1;
    animation: dividerPulse 1.2s ease;
  }

  .section-block > .absolute.inset-0.-z-10 {
    opacity: 0.08;
  }

  .section-block > .max-w-6xl,
  .section-block > .max-w-4xl {
    background: rgba(10, 14, 26, 0.32);
    border: 0;
    border-radius: 24px;
    padding: 2.75rem 2.5rem;
    backdrop-filter: blur(10px);
    box-shadow: 0 0 18px rgba(255, 140, 120, 0.1);
    transition: box-shadow 0.6s ease, background 0.6s ease;
    position: relative;
    overflow: hidden;
  }

  .section-block > .max-w-6xl::before,
  .section-block > .max-w-4xl::before {
    content: '';
    position: absolute;
    inset: -40% -30%;
    background: linear-gradient(
      120deg,
      transparent 35%,
      rgba(255, 179, 106, 0.16) 48%,
      rgba(255, 133, 182, 0.24) 55%,
      transparent 70%
    );
    opacity: 0.55;
    transform: translateX(-35%);
    animation: panelSheen 12s ease-in-out infinite;
