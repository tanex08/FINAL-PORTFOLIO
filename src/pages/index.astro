---
import Layout from '../components/Layout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import Card from '../components/Card.astro';

const portfolioData = {
  about: {
    intro: "I'm a passionate AI specialist and full-stack developer dedicated to building intelligent systems that solve real-world problems.",
    bio: "Currently pursuing a Bachelor of Science in Information Technology at USTP, specializing in Web Development and IoT. My expertise spans machine learning, computer vision, and modern web technologies."
  },
  services: [
    { icon: '🤖', title: 'AI Model Development', description: 'Custom ML models for classification, regression, and predictive analytics', tags: ['TensorFlow', 'PyTorch', 'Custom Models'] },
    { icon: '👁️', title: 'Computer Vision', description: 'Object detection, image recognition, and real-time video analysis', tags: ['OpenCV', 'YOLO', 'CNN'] },
    { icon: '💬', title: 'Chatbots & NLP', description: 'Intelligent conversational AI and natural language processing', tags: ['LLM', 'N8N', 'Ollama'] },
    { icon: '🔗', title: 'Data Integration', description: 'ETL pipelines and seamless system orchestration', tags: ['REST API', 'GraphQL', 'Data Flow'] },
    { icon: '📊', title: 'Data Annotation', description: 'High-quality dataset preparation and labeling', tags: ['Labeling', 'QA', 'Validation'] },
    { icon: '🚀', title: 'MLOps & Deployment', description: 'Production-ready model deployment and scaling', tags: ['Docker', 'CI/CD', 'Monitoring'] }
  ],
  expertise: [
    { title: 'Machine Learning', level: 95, skills: 'Neural Networks • Deep Learning • Model Optimization' },
    { title: 'Computer Vision', level: 90, skills: 'CNN • Object Detection • Image Classification' },
    { title: 'NLP & LLMs', level: 85, skills: 'Text Analysis • Language Models • Prompt Engineering' },
    { title: 'Full-Stack Dev', level: 92, skills: 'Frontend • Backend • Databases • DevOps' }
  ],
  experience: [
    {
      title: 'AI Developer',
      company: 'CEPALCO',
      date: '2026 - Present',
      description: 'Developing AI solutions for energy management using Ollama and N8N workflow automation.',
      tags: ['Ollama', 'N8N', 'Llama3.2', 'Docker']
    },
    {
      title: 'Data Annotator',
      company: 'Remotasks',
      date: '2022 - 2024',
      description: 'Performed data annotation for NLP and computer vision projects.',
      tags: ['NER', 'Sentiment Analysis', 'Data Labeling']
    }
  ],
  projects: [
    {
      title: 'AI Dress Code Detection',
      description: 'Computer vision system for dress code compliance detection using Roboflow and CNN on Raspberry Pi.',
      tags: ['Roboflow', 'Python', 'Raspberry Pi', 'Computer Vision']
    },
    {
      title: 'Online Catering Platform',
      description: 'Full-stack web application for catering service management with real-time tracking.',
      tags: ['HTML/CSS', 'Tailwind', 'MongoDB', 'Node.js', 'Docker']
    },
    {
      title: 'CEPALCO AI Ticketing',
      description: 'Smart ticketing system powered  by AI for automated ticket classification and routing.',
      tags: ['Python', 'AI/ML', 'API', 'N8N']
    }
  ]
};
---

<Layout title="Tristan Jay - AI Specialist Portfolio">
  <canvas id="constellationCanvas" class="constellation-canvas" aria-hidden="true"></canvas>
  <div id="constellationCursor" class="constellation-cursor" aria-hidden="true"></div>
  <!-- Hero Section with animated gradient background -->
  <section id="home" class="section-block section-accent reveal relative min-h-screen overflow-hidden pt-24 pb-16" data-accent="rgba(0, 255, 136, 0.25)" data-animate="fade" data-mission="Home" data-xp="10">
    <!-- Animated background elements -->
    <div class="absolute inset-0 -z-10">
      <!-- Gradient animated background -->
      <div class="absolute inset-0 bg-gradient-to-br from-neon-green/5 via-dark-primary to-neon-blue/5 animate-gradientShift"></div>
      <!-- Floating circles -->
      <div class="absolute top-20 right-20 w-96 h-96 bg-neon-green/10 rounded-full blur-3xl animate-orbitLarge"></div>
      <div class="absolute bottom-20 left-20 w-80 h-80 bg-neon-blue/10 rounded-full blur-3xl animate-orbitMedium" style="animation-delay: 2s;"></div>
      <div class="absolute top-1/2 right-1/4 w-72 h-72 bg-neon-purple/5 rounded-full blur-3xl animate-orbitSmall" style="animation-delay: 4s;"></div>
    </div>

    <div class="hero-top">
      <span class="hero-email">gaid.tristan123@gmail.com</span>
      <nav class="hero-nav">
        <a href="#about">About</a>
        <a href="#projects">Work</a>
        <a href="#contact">Contact</a>
      </nav>
    </div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="hero-grid">
        <div class="hero-left reveal" data-animate="left">
          <p class="hero-kicker">Hello! I'm</p>
          <h1 class="hero-name">TRISTAN JAY</h1>
          <p class="hero-sub">AI Specialist</p>
        </div>

        <div class="hero-center reveal" data-animate="up">
          <div class="hero-avatar">
            <canvas id="hero3d" class="hero-3d" aria-label="3D hero figure"></canvas>
            <div id="hero3dFallback" class="hero-3d-fallback" aria-hidden="true">3D model not loaded</div>
            <span class="hero-glow"></span>
          </div>
        </div>

        <div class="hero-right reveal" data-animate="right">
          <p class="hero-role-top">An</p>
          <h2 class="hero-role">AI ENGINEER</h2>
          <h3 class="hero-role-sub">FULL-STACK DEV</h3>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section with wave animation background -->
  <section id="about" class="section-block section-accent reveal relative py-24 overflow-hidden" data-accent="rgba(0, 150, 255, 0.22)" data-animate="up" data-mission="About" data-xp="15">
    <!-- Animated tech wave background -->
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 opacity-30" style="background: linear-gradient(45deg, rgba(0, 255, 136, 0.1) 25%, transparent 25%, transparent 75%, rgba(0, 255, 136, 0.1) 75%, rgba(0, 255, 136, 0.1)), linear-gradient(45deg, rgba(0, 255, 136, 0.1) 25%, transparent 25%, transparent 75%, rgba(0, 255, 136, 0.1) 75%, rgba(0, 255, 136, 0.1)); background-size: 100px 100px; background-position: 0 0, 50px 50px; animation: gridFlow 30s linear infinite;"></div>
      <div class="absolute top-0 right-0 w-96 h-96 bg-gradient-to-bl from-neon-green/20 to-transparent blur-3xl rounded-full animate-float"></div>
      <div class="absolute bottom-0 left-0 w-96 h-96 bg-gradient-to-tr from-neon-blue/20 to-transparent blur-3xl rounded-full animate-float" style="animation-delay: 1s;"></div>
    </div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="reveal" data-animate="up">
        <SectionTitle title="About Me" subtitle="Who I Am and What I Do" />
      </div>
      
      <div class="grid lg:grid-cols-2 gap-12">
        <div class="reveal" data-animate="left">
          <h3 class="text-3xl font-bold text-neon-green mb-4">Passionate About Innovation</h3>
          <p class="text-gray-300 leading-relaxed mb-4">{portfolioData.about.intro}</p>
          <p class="text-gray-400 leading-relaxed">{portfolioData.about.bio}</p>
        </div>

        <div class="grid grid-cols-1 gap-4 reveal" data-animate="right">
          {[
            { icon: '⚙️', title: 'Technologies', desc: 'Python, JavaScript, React, Docker, TensorFlow' },
            { icon: '🎯', title: 'Specialization', desc: 'Machine Learning, Computer Vision, AI Development' },
            { icon: '🚀', title: 'Focus', desc: 'Building scalable, intelligent solutions' }
          ].map((skill) => (
            <div class="p-5 bg-dark-secondary/40 backdrop-blur-lg border border-neon-green/20 rounded-xl hover:border-neon-green/50 hover:bg-dark-secondary/60 transition-all group">
              <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">{skill.icon}</div>
              <h4 class="text-lg font-semibold text-neon-green">{skill.title}</h4>
              <p class="text-sm text-gray-400">{skill.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section with particle background -->
  <section id="services" class="section-block section-accent reveal relative py-24 overflow-hidden" data-accent="rgba(138, 43, 226, 0.2)" data-animate="up" data-mission="Services" data-xp="20">
    <!-- Particle/dot pattern background -->
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle, rgba(0, 255, 136, 0.1) 1px, transparent 1px); background-size: 50px 50px; opacity: 0.5;"></div>
      <div class="absolute top-1/2 left-0 w-96 h-96 bg-neon-blue/20 rounded-full blur-3xl animate-orbitSmall" style="animation-delay: 0.5s;"></div>
      <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-neon-green/10 rounded-full blur-3xl animate-orbitMedium" style="animation-delay: 1s;"></div>
    </div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="reveal" data-animate="up">
        <SectionTitle title="Services" subtitle="What I Offer" />
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {portfolioData.services.map((service, idx) => (
          <div class="reveal" data-animate="up" data-delay={idx * 90}>
            <Card
              icon={service.icon}
              title={service.title}
              description={service.description}
              tags={service.tags}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Expertise Section with flowing lines background -->
  <section id="expertise" class="section-block section-accent reveal relative py-24 overflow-hidden" data-accent="rgba(0, 255, 136, 0.22)" data-animate="up" data-mission="Expertise" data-xp="20">
    <div class="absolute inset-0 -z-10">
      <!-- Flowing tech lines -->
      <div class="absolute inset-0 opacity-20" style="background-image: linear-gradient(90deg, rgba(0, 255, 136, 0.2) 1px, transparent 1px), linear-gradient(0deg, rgba(0, 150, 255, 0.2) 1px, transparent 1px); background-size: 100px 100px; animation: gridFlow 40s linear infinite;"></div>
      <div class="absolute top-20 left-1/4 w-80 h-80 bg-neon-purple/15 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-20 right-1/3 w-96 h-96 bg-neon-green/15 rounded-full blur-3xl animate-float" style="animation-delay: 2s;"></div>
    </div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="reveal" data-animate="up">
        <SectionTitle title="Expertise" subtitle="Skills & Proficiencies" />
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        {portfolioData.expertise.map((exp, idx) => (
          <div class="card-glass reveal" data-animate="up" data-delay={idx * 120}>
            <h3 class="text-xl font-bold text-neon-green mb-4">{exp.title}</h3>
            <div class="w-full bg-neon-green/10 rounded-full h-2 mb-3 overflow-hidden">
              <div class="bg-gradient-to-r from-neon-green via-neon-blue to-neon-purple h-full transition-all duration-600" style={`width: ${exp.level}%`}></div>
            </div>
            <div class="flex justify-between items-center mb-3">
              <span class="text-sm font-semibold text-neon-green">{exp.level}%</span>
            </div>
            <p class="text-xs text-gray-400 leading-relaxed">{exp.skills}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tech Stack Section -->
  <section id="tech-stack" class="section-block section-accent reveal relative py-24 overflow-hidden" data-accent="rgba(0, 150, 255, 0.18)" data-animate="up">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle, rgba(0, 150, 255, 0.08) 1px, transparent 1px); background-size: 70px 70px;"></div>
      <div class="absolute top-10 right-10 w-72 h-72 bg-neon-blue/10 rounded-full blur-3xl animate-float"></div>
      <div class="absolute bottom-10 left-10 w-80 h-80 bg-neon-green/10 rounded-full blur-3xl animate-float" style="animation-delay: 1.2s;"></div>
    </div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="reveal" data-animate="up">
        <SectionTitle title="Tech Stack" subtitle="Tools I Build With" />
      </div>
      <div class="tech-grid-icons">
        {[
          { name: 'React', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/react/react-original.svg' },
          { name: 'HTML', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/html5/html5-original.svg' },
          { name: 'CSS', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/css3/css3-original.svg' },
          { name: 'Tailwind', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/tailwindcss/tailwindcss-plain.svg' },
          { name: 'Astro 6', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/astro/astro-original.svg' },
          { name: 'Next.js', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/nextjs/nextjs-original.svg' },
          { name: 'Node.js', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/nodejs/nodejs-original.svg' },
          { name: 'JavaScript', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/javascript/javascript-original.svg' },
          { name: 'Flutter', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/flutter/flutter-original.svg' },
          { name: 'Python', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/python/python-original.svg' },
          { name: 'Django', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/django/django-plain.svg' },
          { name: 'Express.js', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/express/express-original.svg' },
          { name: 'Docker', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/docker/docker-original.svg' },
          { name: 'MongoDB', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mongodb/mongodb-original.svg' },
          { name: 'PostgreSQL', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/postgresql/postgresql-original.svg' },
          { name: 'MySQL', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mysql/mysql-original.svg' },
        ].map((tech, idx) => (
          <div class="tech-card reveal" data-animate="up" data-delay={idx * 60}>
            <img class="tech-icon" src={tech.icon} alt={`${tech.name} logo`} loading="lazy" />
            <div class="tech-name">{tech.name}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Experience Section with gradient flow background -->
  <section id="experience" class="section-block section-accent reveal relative py-24 overflow-hidden" data-accent="rgba(0, 150, 255, 0.22)" data-animate="up" data-mission="Experience" data-xp="20">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-gradient-to-br from-neon-blue/10 via-dark-primary to-neon-green/10 animate-gradientShift"></div>
      <div class="absolute left-0 top-1/3 w-96 h-96 bg-neon-blue/20 rounded-full blur-3xl opacity-50"></div>
      <div class="absolute right-0 bottom-0 w-96 h-96 bg-neon-green/20 rounded-full blur-3xl opacity-50 animate-float" style="animation-delay: 1s;"></div>
    </div>

    <div class="max-w-4xl mx-auto px-6 relative z-10">
      <div class="reveal" data-animate="up">
        <SectionTitle title="Experience" subtitle="My Professional Journey" />
      </div>
      <div class="space-y-8">
        {portfolioData.experience.map((job, idx) => (
          <div class="card-glass reveal" data-animate="up" data-delay={idx * 140}>
            <div class="flex items-start justify-between mb-3">
              <div>
                <h3 class="text-xl font-bold text-neon-green">{job.title}</h3>
                <p class="text-sm text-gray-400">{job.company}</p>
              </div>
              <span class="text-sm font-semibold text-neon-blue">{job.date}</span>
            </div>
            <p class="text-gray-300 mb-4 leading-relaxed">{job.description}</p>
            <div class="flex flex-wrap gap-2">
              {job.tags.map((tag) => (
                <span class="px-2 py-1 text-xs bg-neon-green/15 text-neon-green border border-neon-green/30 rounded-full">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Projects Section with scattered particles background -->
  <section id="projects" class="section-block section-accent reveal relative py-24 overflow-hidden" data-accent="rgba(138, 43, 226, 0.22)" data-animate="up" data-mission="Projects" data-xp="25">
    <div class="absolute inset-0 -z-10">
      <!-- Scattered particles -->
      {[...Array(25)].map((_, i) => (
        <div
          class="absolute rounded-full opacity-30 animate-pulse"
          style={{
            width: Math.random() * 100 + 50 + 'px',
            height: Math.random() * 100 + 50 + 'px',
            background: `radial-gradient(circle, ${['rgba(0, 255, 136, 0.2)', 'rgba(0, 150, 255, 0.2)', 'rgba(138, 43, 226, 0.2)'][Math.floor(Math.random() * 3)]}, transparent)`,
            left: Math.random() * 100 + '%',
            top: Math.random() * 100 + '%',
            animationDelay: Math.random() * 2 + 's'
          }}
        ></div>
      ))}
    </div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="reveal" data-animate="up">
        <SectionTitle title="Projects" subtitle="Featured Work" />
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {portfolioData.projects.map((project, idx) => (
          <div class="reveal" data-animate="up" data-delay={idx * 100}>
            <Card
              title={project.title}
              description={project.description}
              tags={project.tags}
              href="#"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Education Section with minimal animated background -->
  <section id="education" class="section-block section-accent reveal relative py-24" data-accent="rgba(0, 255, 136, 0.2)" data-animate="up" data-mission="Education" data-xp="15">
    <div class="absolute inset-0 -z-10 opacity-20">
      <div class="absolute inset-0" style="background-image: repeating-linear-gradient(45deg, rgba(0, 255, 136, 0.1) 0px, rgba(0, 255, 136, 0.1) 1px, transparent 1px, transparent 100px); animation: gridFlow 60s linear infinite;"></div>
    </div>

    <div class="max-w-4xl mx-auto px-6 relative z-10">
      <div class="reveal" data-animate="up">
        <SectionTitle title="Education" subtitle="Learning & Development" />
      </div>
      <div class="card-glass max-w-2xl mx-auto reveal" data-animate="up" data-delay="120">
        <h3 class="text-2xl font-bold text-neon-green mb-2">Bachelor of Science in Information Technology</h3>
        <p class="text-gray-300 mb-2">University of Science and Technology of Southern Philippines (USTP)</p>
        <p class="text-sm text-neon-blue font-semibold mb-4">Expected: 2026</p>
        <p class="text-gray-400">Specialization in Web Development and Internet of Things</p>
      </div>
    </div>
  </section>

  <!-- Certifications Section with radial gradient background -->
  <section id="certifications" class="section-block section-accent reveal relative py-24 overflow-hidden" data-accent="rgba(0, 150, 255, 0.2)" data-animate="up" data-mission="Certifications" data-xp="15">
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-gradient-radial from-neon-green/20 to-transparent rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-0 right-0 w-80 h-80 bg-gradient-radial from-neon-blue/20 to-transparent rounded-full blur-3xl animate-float" style="animation-delay: 1.5s;"></div>
    </div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="reveal" data-animate="up">
        <SectionTitle title="Certifications" subtitle="Professional Credentials" />
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { icon: '🏆', title: 'CCNA Enterprise Networking', org: 'Cisco', date: 'May 2025' },
          { icon: '🔒', title: 'CyberOps Associate', org: 'Cisco', date: 'Dec 26, 2025' },
          { icon: '🛡️', title: 'Intro to Cybersecurity', org: 'Cisco', date: 'Sept 14, 2025' }
        ].map((cert, idx) => (
          <div class="card-glass text-center reveal" data-animate="up" data-delay={idx * 120}>
            <div class="text-5xl mb-3">{cert.icon}</div>
            <h3 class="text-lg font-semibold text-neon-green mb-1">{cert.title}</h3>
            <p class="text-sm text-gray-400 mb-2">{cert.org}</p>
            <time class="text-xs text-neon-blue font-semibold">{cert.date}</time>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Game Section -->
  <section id="game" class="section-block section-accent reveal relative py-24 overflow-hidden" data-accent="rgba(0, 255, 136, 0.22)" data-animate="up" data-mission="Game" data-xp="20">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 opacity-30" style="background-image: radial-gradient(circle, rgba(0, 255, 136, 0.12) 1px, transparent 1px); background-size: 60px 60px;"></div>
      <div class="absolute top-12 left-1/3 w-80 h-80 bg-neon-green/10 rounded-full blur-3xl animate-float"></div>
      <div class="absolute bottom-10 right-1/4 w-96 h-96 bg-neon-blue/10 rounded-full blur-3xl animate-float" style="animation-delay: 1s;"></div>
    </div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="reveal" data-animate="up">
        <SectionTitle title="Mini Game" subtitle="Take a 30‑Second Break" />
      </div>

      <div class="game-shell reveal" data-animate="up" data-delay="120">
        <div class="game-panel">
          <canvas id="gameCanvas" width="900" height="520" aria-label="Astro Dodge game"></canvas>
        </div>
        <div class="game-ui">
          <div class="game-stats">
            <div class="stat-card">
              <span class="stat-label">Score</span>
              <span id="gameScore" class="stat-value">0</span>
            </div>
            <div class="stat-card">
              <span class="stat-label">Best</span>
              <span id="gameBest" class="stat-value">0</span>
            </div>
            <div class="stat-card">
              <span class="stat-label">Lives</span>
              <span id="gameLives" class="stat-value">3</span>
            </div>
          </div>

          <p class="game-desc">
            Pilot the neon ship, dodge incoming drones, and survive as long as you can.
          </p>
          <div class="game-controls">
            <button id="startGameBtn" class="btn-neon">Start</button>
            <button id="pauseGameBtn" class="btn-neon-outline">Pause</button>
            <button id="resetGameBtn" class="btn-neon-outline">Reset</button>
          </div>
          <ul class="game-hints">
            <li>Move: Arrow keys or WASD</li>
            <li>Boost: Shift</li>
            <li>Mobile: Drag on the canvas</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section with electric effect background -->
  <section id="contact" class="section-block section-accent reveal relative py-24 overflow-hidden" data-accent="rgba(138, 43, 226, 0.2)" data-animate="up" data-mission="Contact" data-xp="15">
    <div class="absolute inset-0 -z-10">
      <!-- Electric lines effect -->
      <div class="absolute inset-0 opacity-20" style="background: linear-gradient(90deg, transparent 0%, rgba(0, 255, 136, 0.1) 50%, transparent 100%), linear-gradient(0deg, transparent 0%, rgba(0, 150, 255, 0.1) 50%, transparent 100%); background-size: 200% 200%; animation: gradientShift 8s ease infinite;"></div>
