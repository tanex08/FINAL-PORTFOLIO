  .section-accent::after {
    content: '';
    position: absolute;
    inset: -10% 0 0 0;
    background: radial-gradient(60% 60% at 50% 0%, var(--section-accent) 0%, transparent 70%);
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s ease, transform 0.8s ease;
    pointer-events: none;
    z-index: 0;
  }

  .section-accent.is-active::after {
    opacity: 0.2;
    transform: translateY(0);
  }

  .section-accent::before {
    content: '';
    position: absolute;
    inset: -20% -10%;
    background: radial-gradient(50% 50% at 10% 20%, rgba(255, 168, 210, 0.12), transparent 60%),
      radial-gradient(40% 40% at 80% 30%, rgba(255, 179, 106, 0.12), transparent 60%),
      radial-gradient(45% 45% at 30% 80%, rgba(161, 227, 255, 0.1), transparent 60%);
    opacity: 0.18;
    filter: blur(20px);
    animation: aiNebula 16s ease-in-out infinite;
    pointer-events: none;
    z-index: 0;
  }

  @keyframes aiNebula {
    0%, 100% {
      transform: translate3d(0, 0, 0) scale(1);
    }
    50% {
      transform: translate3d(-2%, 1%, 0) scale(1.05);
    }
  }

  .constellation-canvas {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
