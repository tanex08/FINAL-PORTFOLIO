  .globe-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
    gap: 2rem;
    align-items: center;
  }

  .globe-stage {
    position: relative;
    min-height: 420px;
    display: grid;
    place-items: center;
    transition: transform 0.4s ease;
  }

  .globe-stage::before {
    content: '';
    position: absolute;
    inset: 5%;
    border-radius: 50%;
    border: 1px solid rgba(255, 168, 210, 0.35);
    box-shadow: 0 0 40px rgba(255, 140, 180, 0.35), inset 0 0 30px rgba(255, 140, 180, 0.2);
    opacity: 0.8;
    pointer-events: none;
    animation: globePulse 5s ease-in-out infinite;
  }

  .globe-stage::after {
    content: '';
    position: absolute;
    width: 75%;
    height: 75%;
    border-radius: 50%;
    border: 1px dashed rgba(255, 179, 106, 0.35);
    box-shadow: 0 0 26px rgba(255, 179, 106, 0.3);
    opacity: 0.7;
    pointer-events: none;
    animation: globeSpin 18s linear infinite;
  }

  #globeCanvas {
    width: min(520px, 90vw);
    height: min(520px, 90vw);
    display: block;
    border-radius: 50%;
    background: radial-gradient(circle at 40% 40%, rgba(255, 168, 210, 0.15), rgba(10, 14, 26, 0.2) 60%, transparent 75%);
    box-shadow: 0 0 40px rgba(255, 140, 180, 0.35);
  }

