<script>
  // Smooth scroll behavior is handled by CSS
  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener('click', function (e) {
      const href = this.getAttribute('href');
      if (href !== '#' && document.querySelector(href)) {
        e.preventDefault();
        document.querySelector(href).scrollIntoView({
          behavior: 'smooth',
        });
      }
    });
  });

  const revealItems = document.querySelectorAll('.reveal');
  revealItems.forEach((el) => {
    const delay = el.getAttribute('data-delay');
    if (delay) {
      el.style.transitionDelay = `${delay}ms`;
    }
  });

  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.18, rootMargin: '0px 0px -10% 0px' }
  );

  revealItems.forEach((el) => revealObserver.observe(el));

  const sections = document.querySelectorAll('.section-accent');
  const sectionObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const accent = entry.target.getAttribute('data-accent');
          if (accent) {
            document.body.style.setProperty('--section-accent', accent);
          }
          sections.forEach((section) => section.classList.remove('is-active'));
          entry.target.classList.add('is-active');
        }
      });
    },
    { threshold: 0.5 }
  );

  sections.forEach((section) => sectionObserver.observe(section));

  const constellationCanvas = document.getElementById('constellationCanvas');
  const constellationCursor = document.getElementById('constellationCursor');
  const heroCanvas = document.getElementById('hero3d');
  let mouseX = window.innerWidth / 2;
  let mouseY = window.innerHeight / 2;
  let constellationActive = false;

  if (constellationCanvas) {
    const ctx = constellationCanvas.getContext('2d');
    const stars = [];
    const starCount = 70;
    const linkDistance = 130;

    const resizeCanvas = () => {
      const dpr = window.devicePixelRatio || 1;
      constellationCanvas.width = window.innerWidth * dpr;
      constellationCanvas.height = window.innerHeight * dpr;
      constellationCanvas.style.width = `${window.innerWidth}px`;
      constellationCanvas.style.height = `${window.innerHeight}px`;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };

    const createStars = () => {
      stars.length = 0;
      for (let i = 0; i < starCount; i += 1) {
        stars.push({
          x: Math.random() * window.innerWidth,
          y: Math.random() * window.innerHeight,
          r: Math.random() * 1.8 + 0.6,
          vx: (Math.random() - 0.5) * 0.2,
          vy: (Math.random() - 0.5) * 0.2,
        });
      }
    };

    const draw = () => {
      ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);
      ctx.fillStyle = 'rgba(0, 255, 136, 0.7)';

      stars.forEach((star) => {
        star.x += star.vx;
        star.y += star.vy;
        if (star.x < 0 || star.x > window.innerWidth) star.vx *= -1;
        if (star.y < 0 || star.y > window.innerHeight) star.vy *= -1;
        ctx.beginPath();
        ctx.arc(star.x, star.y, star.r, 0, Math.PI * 2);
        ctx.fill();
      });

      ctx.strokeStyle = 'rgba(0, 255, 136, 0.12)';
      for (let i = 0; i < stars.length; i += 1) {
        for (let j = i + 1; j < stars.length; j += 1) {
          const dx = stars[i].x - stars[j].x;
          const dy = stars[i].y - stars[j].y;
          const dist = Math.hypot(dx, dy);
          if (dist < linkDistance) {
            ctx.globalAlpha = 1 - dist / linkDistance;
            ctx.beginPath();
            ctx.moveTo(stars[i].x, stars[i].y);
            ctx.lineTo(stars[j].x, stars[j].y);
            ctx.stroke();
          }
        }
      }

      if (constellationActive) {
        ctx.strokeStyle = 'rgba(0, 150, 255, 0.45)';
        stars.forEach((star) => {
          const dx = star.x - mouseX;
          const dy = star.y - mouseY;
          const dist = Math.hypot(dx, dy);
          if (dist < linkDistance) {
            ctx.globalAlpha = 1 - dist / linkDistance;
            ctx.beginPath();
            ctx.moveTo(star.x, star.y);
            ctx.lineTo(mouseX, mouseY);
            ctx.stroke();
          }
        });
      }

      ctx.globalAlpha = 1;
      requestAnimationFrame(draw);
    };

    resizeCanvas();
    createStars();
    requestAnimationFrame(draw);

    window.addEventListener('resize', () => {
      resizeCanvas();
      createStars();
    });
  }

  window.addEventListener('mousemove', (e) => {
    mouseX = e.clientX;
    mouseY = e.clientY;
    if (constellationCursor) {
      constellationCursor.style.transform = `translate(${mouseX}px, ${mouseY}px)`;
    }
  });

  document.querySelectorAll('.section-block').forEach((section) => {
    section.addEventListener('mouseenter', () => {
      constellationActive = true;
    });
    section.addEventListener('mouseleave', () => {
      constellationActive = false;
    });
  });

  // 3D hero is initialized in the module script below.

  const canvas = document.getElementById('gameCanvas');
  if (canvas) {
    const ctx = canvas.getContext('2d');
    const scoreEl = document.getElementById('gameScore');
    const bestEl = document.getElementById('gameBest');
    const livesEl = document.getElementById('gameLives');
    const startBtn = document.getElementById('startGameBtn');
    const pauseBtn = document.getElementById('pauseGameBtn');
    const resetBtn = document.getElementById('resetGameBtn');

    const WIDTH = 900;
    const HEIGHT = 520;
    const dpr = window.devicePixelRatio || 1;
    canvas.width = WIDTH * dpr;
    canvas.height = HEIGHT * dpr;
    ctx.scale(dpr, dpr);

    const state = {
      running: false,
      paused: false,
      score: 0,
      best: Number(localStorage.getItem('astroBest') || 0),
      lives: 3,
      lastTime: 0,
      spawnTimer: 0,
      spawnInterval: 900,
      speedBoost: false,
      pointerActive: false,
      pointerX: WIDTH / 2,
      pointerY: HEIGHT / 2,
    };

    const player = {
      x: WIDTH / 2,
      y: HEIGHT * 0.75,
      r: 14,
      speed: 260,
    };

    const enemies = [];
    const particles = [];
    const keys = new Set();

    bestEl.textContent = state.best;
    livesEl.textContent = state.lives;

    function resetGame() {
      state.score = 0;
      state.lives = 3;
      state.spawnInterval = 900;
      state.spawnTimer = 0;
      enemies.length = 0;
      particles.length = 0;
      player.x = WIDTH / 2;
      player.y = HEIGHT * 0.75;
      livesEl.textContent = state.lives;
      scoreEl.textContent = state.score;
    }

    function spawnEnemy() {
      const edge = Math.floor(Math.random() * 4);
      const size = 10 + Math.random() * 16;
      let x = 0;
      let y = 0;
      if (edge === 0) {
        x = Math.random() * WIDTH;
        y = -20;
      } else if (edge === 1) {
        x = WIDTH + 20;
        y = Math.random() * HEIGHT;
      } else if (edge === 2) {
        x = Math.random() * WIDTH;
        y = HEIGHT + 20;
      } else {
        x = -20;
        y = Math.random() * HEIGHT;
      }
      enemies.push({
        x,
        y,
        r: size,
        speed: 60 + Math.random() * 100,
      });
    }

    function spawnParticles(x, y, count) {
      for (let i = 0; i < count; i += 1) {
        particles.push({
          x,
          y,
          vx: (Math.random() - 0.5) * 200,
          vy: (Math.random() - 0.5) * 200,
          life: 0.6 + Math.random() * 0.6,
        });
      }
    }

    function update(dt) {
      const speed = player.speed * (state.speedBoost ? 1.6 : 1);
      let vx = 0;
      let vy = 0;

      if (state.pointerActive) {
        const dx = state.pointerX - player.x;
        const dy = state.pointerY - player.y;
        const dist = Math.hypot(dx, dy) || 1;
        vx = (dx / dist) * speed;
        vy = (dy / dist) * speed;
        if (dist < 6) {
          vx = 0;
          vy = 0;
        }
      } else {
        if (keys.has('ArrowLeft') || keys.has('a')) vx -= speed;
        if (keys.has('ArrowRight') || keys.has('d')) vx += speed;
        if (keys.has('ArrowUp') || keys.has('w')) vy -= speed;
        if (keys.has('ArrowDown') || keys.has('s')) vy += speed;
      }

      player.x = Math.max(player.r, Math.min(WIDTH - player.r, player.x + vx * dt));
      player.y = Math.max(player.r, Math.min(HEIGHT - player.r, player.y + vy * dt));

      state.spawnTimer += dt * 1000;
      if (state.spawnTimer > state.spawnInterval) {
        state.spawnTimer = 0;
        spawnEnemy();
        state.spawnInterval = Math.max(380, state.spawnInterval - 6);
      }

      for (let i = enemies.length - 1; i >= 0; i -= 1) {
        const enemy = enemies[i];
        const dx = player.x - enemy.x;
        const dy = player.y - enemy.y;
        const dist = Math.hypot(dx, dy) || 1;
        enemy.x += (dx / dist) * enemy.speed * dt;
        enemy.y += (dy / dist) * enemy.speed * dt;

        if (dist < player.r + enemy.r) {
          enemies.splice(i, 1);
          state.lives -= 1;
          livesEl.textContent = state.lives;
          spawnParticles(player.x, player.y, 16);
          if (state.lives <= 0) {
            state.running = false;
            state.paused = false;
            pauseBtn.textContent = 'Pause';
          }
        }
      }

      for (let i = particles.length - 1; i >= 0; i -= 1) {
        const p = particles[i];
        p.life -= dt;
        p.x += p.vx * dt;
        p.y += p.vy * dt;
        if (p.life <= 0) particles.splice(i, 1);
      }

      if (state.running) {
        state.score += Math.floor(dt * 120);
        scoreEl.textContent = state.score;
        if (state.score > state.best) {
          state.best = state.score;
          bestEl.textContent = state.best;
          localStorage.setItem('astroBest', state.best);
        }
      }
    }

    function draw() {
      ctx.clearRect(0, 0, WIDTH, HEIGHT);
      ctx.save();

      const gradient = ctx.createRadialGradient(player.x, player.y, 0, player.x, player.y, 220);
      gradient.addColorStop(0, 'rgba(0, 255, 136, 0.12)');
      gradient.addColorStop(1, 'rgba(0, 0, 0, 0)');
      ctx.fillStyle = gradient;
      ctx.fillRect(0, 0, WIDTH, HEIGHT);

      enemies.forEach((enemy) => {
        ctx.beginPath();
        ctx.fillStyle = 'rgba(0, 150, 255, 0.6)';
        ctx.arc(enemy.x, enemy.y, enemy.r, 0, Math.PI * 2);
        ctx.fill();
      });

      particles.forEach((p) => {
        ctx.beginPath();
        ctx.fillStyle = 'rgba(0, 255, 136, 0.7)';
        ctx.arc(p.x, p.y, 2.2, 0, Math.PI * 2);
        ctx.fill();
      });

      ctx.beginPath();
      ctx.fillStyle = 'rgba(0, 255, 136, 0.9)';
      ctx.moveTo(player.x, player.y - player.r);
      ctx.lineTo(player.x - player.r, player.y + player.r);
      ctx.lineTo(player.x + player.r, player.y + player.r);
      ctx.closePath();
      ctx.fill();

      ctx.restore();
    }

    function loop(timestamp) {
      if (!state.lastTime) state.lastTime = timestamp;
      const dt = Math.min(0.033, (timestamp - state.lastTime) / 1000);
      state.lastTime = timestamp;

      if (state.running && !state.paused) {
        update(dt);
      }
      draw();
      requestAnimationFrame(loop);
    }

    function startGame() {
      if (!state.running) {
        resetGame();
        state.running = true;
      }
    }

    function togglePause() {
      if (!state.running) return;
      state.paused = !state.paused;
      pauseBtn.textContent = state.paused ? 'Resume' : 'Pause';
    }

    function stopGame() {
      state.running = false;
      state.paused = false;
      pauseBtn.textContent = 'Pause';
      resetGame();
    }

    startBtn?.addEventListener('click', startGame);
    pauseBtn?.addEventListener('click', togglePause);
    resetBtn?.addEventListener('click', stopGame);

    window.addEventListener('keydown', (e) => {
      if (['ArrowLeft', 'ArrowRight', 'ArrowUp', 'ArrowDown'].includes(e.key)) e.preventDefault();
      if (e.key === 'Shift') state.speedBoost = true;
      keys.add(e.key.toLowerCase());
      if (e.key === ' ') {
        startGame();
      }
    });

    window.addEventListener('keyup', (e) => {
      if (e.key === 'Shift') state.speedBoost = false;
      keys.delete(e.key.toLowerCase());
    });

    canvas.addEventListener('pointerdown', (e) => {
      state.pointerActive = true;
      const rect = canvas.getBoundingClientRect();
      state.pointerX = ((e.clientX - rect.left) / rect.width) * WIDTH;
      state.pointerY = ((e.clientY - rect.top) / rect.height) * HEIGHT;
      startGame();
    });

    canvas.addEventListener('pointermove', (e) => {
      if (!state.pointerActive) return;
      const rect = canvas.getBoundingClientRect();
      state.pointerX = ((e.clientX - rect.left) / rect.width) * WIDTH;
      state.pointerY = ((e.clientY - rect.top) / rect.height) * HEIGHT;
    });

    window.addEventListener('pointerup', () => {
      state.pointerActive = false;
    });

    requestAnimationFrame(loop);
  }
</script>

<script is:inline type="module">
  import * as THREE from 'https://esm.sh/three@0.161.0';
  import { GLTFLoader } from 'https://esm.sh/three@0.161.0/examples/jsm/loaders/GLTFLoader.js';

  const canvas = document.getElementById('hero3d');
  const fallback = document.getElementById('hero3dFallback');
  if (canvas) {
    console.log('[hero3d] init');
    const scene = new THREE.Scene();
    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.1;
    renderer.physicallyCorrectLights = true;
    const resizeRenderer = () => {
      const rect = canvas.getBoundingClientRect();
      if (rect.width === 0 || rect.height === 0) return;
      renderer.setSize(rect.width, rect.height, false);
      camera.aspect = rect.width / rect.height;
      camera.updateProjectionMatrix();
    };

    const camera = new THREE.PerspectiveCamera(32, 1, 0.1, 100);
    camera.position.set(0, 1.35, 2.1);
    camera.lookAt(0, 1.05, 0);

    const ambient = new THREE.AmbientLight(0x8aa0ff, 0.55);
    scene.add(ambient);

    const keyLight = new THREE.DirectionalLight(0xffffff, 1.4);
    keyLight.position.set(2, 2, 3);
    scene.add(keyLight);

    const rim = new THREE.PointLight(0x8a2be2, 2.0, 10);
    rim.position.set(-2, 1, -2);
    scene.add(rim);

    const fill = new THREE.PointLight(0x00ff88, 1.1, 6);
    fill.position.set(1.5, -1, 2);
    scene.add(fill);

    const hemi = new THREE.HemisphereLight(0xbfd6ff, 0x202430, 0.45);
    scene.add(hemi);

    const loader = new GLTFLoader();
    const modelUrl = '/hero.glb';
    let model = null;
    let baseY = -0.4;

    loader.load(
      modelUrl,
      (gltf) => {
        console.log('[hero3d] model loaded');
        if (fallback) fallback.classList.remove('is-visible');
        model = gltf.scene;
        model.traverse((child) => {
          if (child.isMesh && child.material) {
            const mats = Array.isArray(child.material) ? child.material : [child.material];
            mats.forEach((mat) => {
              if (mat.map) {
                mat.map.colorSpace = THREE.SRGBColorSpace;
              }
              mat.roughness = mat.roughness ?? 0.6;
              mat.metalness = mat.metalness ?? 0.1;
              mat.needsUpdate = true;
            });
            child.castShadow = false;
            child.receiveShadow = false;
          }
        });
        const box = new THREE.Box3().setFromObject(model);
        const size = new THREE.Vector3();
        const center = new THREE.Vector3();
        box.getSize(size);
        box.getCenter(center);
        console.log('[hero3d] model bounds', size);
        model.position.sub(center);

        const targetHeight = 2.2;
        const scale = targetHeight / Math.max(size.y, 0.0001);
        model.scale.setScalar(scale);
        model.position.set(0, 0, 0);
        scene.add(model);

        const scaledBox = new THREE.Box3().setFromObject(model);
        const scaledSize = new THREE.Vector3();
        const scaledCenter = new THREE.Vector3();
        scaledBox.getSize(scaledSize);
        scaledBox.getCenter(scaledCenter);

        const chestY = scaledBox.max.y - scaledSize.y * 0.55;
        const lookY = scaledBox.max.y - scaledSize.y * 0.18;
        const cameraZ = Math.max(scaledSize.y, scaledSize.z) * 1.05;
        camera.position.set(0, lookY + scaledSize.y * 0.05, cameraZ);
        camera.lookAt(0, lookY, 0);

        renderer.localClippingEnabled = true;
        const clipPlane = new THREE.Plane(new THREE.Vector3(0, 1, 0), -chestY);
        model.traverse((child) => {
          if (child.isMesh && child.material) {
            const mats = Array.isArray(child.material) ? child.material : [child.material];
            mats.forEach((mat) => {
              mat.clippingPlanes = [clipPlane];
              mat.clipShadows = true;
              mat.needsUpdate = true;
            });
          }
        });
        resizeRenderer();
        // Debug helper removed.
      },
      undefined,
      (err) => {
        console.error('[hero3d] model failed', err);
        if (fallback) fallback.classList.add('is-visible');
      }
    );

    let targetX = 0;
    let targetY = 0;

    const onMove = (e) => {
      const rect = canvas.getBoundingClientRect();
      const nx = (e.clientX - rect.left) / rect.width - 0.5;
      const ny = (e.clientY - rect.top) / rect.height - 0.5;
      targetX = nx;
      targetY = ny;
    };

    canvas.addEventListener('mousemove', onMove);

    window.addEventListener('resize', resizeRenderer);
    resizeRenderer();

    const clock = new THREE.Clock();
    const animate = () => {
      const t = clock.getElapsedTime();
      if (model) {
        model.rotation.y = targetX * 0.8;
        model.rotation.x = -targetY * 0.5;
        model.position.y = baseY + Math.sin(t * 1.4) * 0.03;
      }
      renderer.render(scene, camera);
      requestAnimationFrame(animate);
    };
    animate();
  }
</script>
