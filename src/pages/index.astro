    background: radial-gradient(circle, rgba(255, 179, 106, 0.9), rgba(255, 179, 106, 0));
    box-shadow: 0 0 12px rgba(255, 179, 106, 0.6);
    pointer-events: none;
    z-index: 119;
    opacity: 0.85;
