    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .globe-btn {
    position: absolute;
    pointer-events: auto;
    background: rgba(12, 12, 22, 0.75);
    border: 1px solid rgba(255, 168, 210, 0.45);
    color: #ffd0e6;
    padding: 0.45rem 0.9rem;
    border-radius: 999px;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    box-shadow: 0 0 18px rgba(255, 140, 180, 0.3);
    backdrop-filter: blur(6px);
    transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.9);
  }

  .globe-btn:hover {
    transform: translate(-50%, -50%) scale(1.08);
    background: rgba(255, 168, 210, 0.18);
    box-shadow: 0 0 26px rgba(255, 140, 180, 0.6);
  }

