    opacity: 0.8;
    animation: holoSweep 1.2s ease;
  }

  @keyframes panelSheen {
    0% { transform: translateX(-35%); opacity: 0.2; }
    50% { transform: translateX(35%); opacity: 0.55; }
    100% { transform: translateX(90%); opacity: 0.2; }
  }

  @keyframes neonPulse {
    0%, 100% { opacity: 0.45; }
    50% { opacity: 1; }
  }

  @keyframes scrollPop {
    0% { opacity: 0.3; box-shadow: 0 0 10px rgba(255, 140, 180, 0.2); }
    50% { opacity: 1; box-shadow: 0 0 55px rgba(255, 179, 106, 0.4); }
    100% { opacity: 0.6; box-shadow: 0 0 30px rgba(255, 140, 180, 0.2); }
  }

  @keyframes scanSweep {
    0% { opacity: 0.15; background-position: 0 0; }
    50% { opacity: 0.4; background-position: 120px 120px; }
    100% { opacity: 0.15; background-position: 240px 240px; }
  }

  @keyframes dividerPulse {
    0% { opacity: 0.2; transform: scaleX(0.6); }
    60% { opacity: 1; transform: scaleX(1); }
    100% { opacity: 0.4; transform: scaleX(1); }
  }

  @keyframes holoSweep {
    0% { transform: translateX(-45%); opacity: 0.2; }
    60% { transform: translateX(35%); opacity: 0.8; }
    100% { transform: translateX(85%); opacity: 0; }
  }

  @keyframes badgeScan {
    0% { transform: translateX(-70%); opacity: 0.1; }
    50% { transform: translateX(20%); opacity: 0.6; }
    100% { transform: translateX(80%); opacity: 0.1; }
