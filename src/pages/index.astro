---
import Layout from '../components/Layout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import Card from '../components/Card.astro';

const portfolioData = {
  about: {
    intro: "I'm a passionate AI specialist and full-stack developer dedicated to building intelligent systems that solve real-world problems.",
    bio: "Currently pursuing a Bachelor of Science in Information Technology at USTP, specializing in Web Development and IoT. My expertise spans machine learning, computer vision, and modern web technologies."
  },
  services: [
    { icon: '🤖', title: 'AI Model Development', description: 'Custom ML models for classification, regression, and predictive analytics', tags: ['TensorFlow', 'PyTorch', 'Custom Models'] },
    { icon: '👁️', title: 'Computer Vision', description: 'Object detection, image recognition, and real-time video analysis', tags: ['OpenCV', 'YOLO', 'CNN'] },
    { icon: '💬', title: 'Chatbots & NLP', description: 'Intelligent conversational AI and natural language processing', tags: ['LLM', 'N8N', 'Ollama'] },
    { icon: '🔗', title: 'Data Integration', description: 'ETL pipelines and seamless system orchestration', tags: ['REST API', 'GraphQL', 'Data Flow'] },
    { icon: '📊', title: 'Data Annotation', description: 'High-quality dataset preparation and labeling', tags: ['Labeling', 'QA', 'Validation'] },
    { icon: '🚀', title: 'MLOps & Deployment', description: 'Production-ready model deployment and scaling', tags: ['Docker', 'CI/CD', 'Monitoring'] }
  ],
  expertise: [
    { title: 'Machine Learning', level: 95, skills: 'Neural Networks • Deep Learning • Model Optimization' },
    { title: 'Computer Vision', level: 90, skills: 'CNN • Object Detection • Image Classification' },
    { title: 'NLP & LLMs', level: 85, skills: 'Text Analysis • Language Models • Prompt Engineering' },
    { title: 'Full-Stack Dev', level: 92, skills: 'Frontend • Backend • Databases • DevOps' }
  ],
  experience: [
    {
      title: 'AI Developer',
      company: 'CEPALCO',
      date: '2026 - Present',
      description: 'Developing AI solutions for energy management using Ollama and N8N workflow automation.',
      tags: ['Ollama', 'N8N', 'Llama3.2', 'Docker']
    },
    {
      title: 'Data Annotator',
      company: 'Remotasks',
      date: '2022 - 2024',
      description: 'Performed data annotation for NLP and computer vision projects.',
      tags: ['NER', 'Sentiment Analysis', 'Data Labeling']
    }
  ],
  projects: [
    {
      title: 'AI Dress Code Detection',
      description: 'Computer vision system for dress code compliance detection using Roboflow and CNN on Raspberry Pi.',
      tags: ['Roboflow', 'Python', 'Raspberry Pi', 'Computer Vision']
    },
    {
      title: 'Online Catering Platform',
      description: 'Full-stack web application for catering service management with real-time tracking.',
      tags: ['HTML/CSS', 'Tailwind', 'MongoDB', 'Node.js', 'Docker']
    },
    {
      title: 'CEPALCO AI Ticketing',
      description: 'Smart ticketing system powered  by AI for automated ticket classification and routing.',
      tags: ['Python', 'AI/ML', 'API', 'N8N']
    }
  ]
};
---

<Layout title="Tristan Jay - AI Specialist Portfolio">
  <!-- Hero Section with animated gradient background -->
  <section id="home" class="section-block section-accent reveal relative min-h-screen flex items-center justify-center overflow-hidden py-20" data-accent="rgba(0, 255, 136, 0.25)" data-animate="fade">
    <!-- Animated background elements -->
    <div class="absolute inset-0 -z-10">
      <!-- Gradient animated background -->
      <div class="absolute inset-0 bg-gradient-to-br from-neon-green/5 via-dark-primary to-neon-blue/5 animate-gradientShift"></div>
      <!-- Floating circles -->
      <div class="absolute top-20 right-20 w-96 h-96 bg-neon-green/10 rounded-full blur-3xl animate-orbitLarge"></div>
      <div class="absolute bottom-20 left-20 w-80 h-80 bg-neon-blue/10 rounded-full blur-3xl animate-orbitMedium" style="animation-delay: 2s;"></div>
      <div class="absolute top-1/2 right-1/4 w-72 h-72 bg-neon-purple/5 rounded-full blur-3xl animate-orbitSmall" style="animation-delay: 4s;"></div>
    </div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Hero Text -->
        <div class="animate-slideInLeft">
          <h1 class="text-6xl lg:text-7xl font-black mb-4 leading-tight">
            <span class="inline-block animate-fadeInDown">Transforming</span>
            <span class="inline-block animate-fadeInDown" style="animation-delay: 0.1s;">Ideas</span>
            <br />
            <span class="inline-block gradient-text-purple animate-fadeInDown" style="animation-delay: 0.2s;">Into Intelligence</span>
          </h1>
          <p class="text-xl text-gray-300 mb-8 animate-slideInUp" style="animation-delay: 0.3s;">
            AI Specialist • Machine Learning • Computer Vision • Full-Stack Developer
          </p>
          <div class="flex gap-4 animate-slideInUp" style="animation-delay: 0.4s;">
            <a href="#projects" class="btn-neon hover:shadow-neon hover:scale-105 transition-all">Explore Work</a>
            <a href="#contact" class="btn-neon-outline hover:border-neon-green/80 transition-all">Get In Touch</a>
          </div>
        </div>

        <!-- Floating Cards -->
        <div class="relative h-96 hidden lg:block">
          <div class="absolute top-0 right-0 w-32 h-32 bg-dark-secondary/60 backdrop-blur-lg border border-neon-green/30 rounded-2xl flex items-center justify-center text-5xl animate-orbitSmall">
            🤖
          </div>
          <div class="absolute top-32 right-40 w-32 h-32 bg-dark-secondary/60 backdrop-blur-lg border border-neon-blue/30 rounded-2xl flex items-center justify-center text-5xl animate-orbitMedium" style="animation-delay: 1s;">
            💻
          </div>
          <div class="absolute top-64 right-20 w-32 h-32 bg-dark-secondary/60 backdrop-blur-lg border border-neon-purple/30 rounded-2xl flex items-center justify-center text-5xl animate-orbitLarge" style="animation-delay: 2s;">
            👁️
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section with wave animation background -->
  <section id="about" class="section-block section-accent reveal relative py-24 overflow-hidden" data-accent="rgba(0, 150, 255, 0.22)" data-animate="up">
    <!-- Animated tech wave background -->
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 opacity-30" style="background: linear-gradient(45deg, rgba(0, 255, 136, 0.1) 25%, transparent 25%, transparent 75%, rgba(0, 255, 136, 0.1) 75%, rgba(0, 255, 136, 0.1)), linear-gradient(45deg, rgba(0, 255, 136, 0.1) 25%, transparent 25%, transparent 75%, rgba(0, 255, 136, 0.1) 75%, rgba(0, 255, 136, 0.1)); background-size: 100px 100px; background-position: 0 0, 50px 50px; animation: gridFlow 30s linear infinite;"></div>
      <div class="absolute top-0 right-0 w-96 h-96 bg-gradient-to-bl from-neon-green/20 to-transparent blur-3xl rounded-full animate-float"></div>
      <div class="absolute bottom-0 left-0 w-96 h-96 bg-gradient-to-tr from-neon-blue/20 to-transparent blur-3xl rounded-full animate-float" style="animation-delay: 1s;"></div>
    </div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="reveal" data-animate="up">
        <SectionTitle title="About Me" subtitle="Who I Am and What I Do" />
      </div>
      
      <div class="grid lg:grid-cols-2 gap-12">
        <div class="reveal" data-animate="left">
          <h3 class="text-3xl font-bold text-neon-green mb-4">Passionate About Innovation</h3>
          <p class="text-gray-300 leading-relaxed mb-4">{portfolioData.about.intro}</p>
          <p class="text-gray-400 leading-relaxed">{portfolioData.about.bio}</p>
        </div>

        <div class="grid grid-cols-1 gap-4 reveal" data-animate="right">
          {[
            { icon: '⚙️', title: 'Technologies', desc: 'Python, JavaScript, React, Docker, TensorFlow' },
            { icon: '🎯', title: 'Specialization', desc: 'Machine Learning, Computer Vision, AI Development' },
            { icon: '🚀', title: 'Focus', desc: 'Building scalable, intelligent solutions' }
          ].map((skill) => (
            <div class="p-5 bg-dark-secondary/40 backdrop-blur-lg border border-neon-green/20 rounded-xl hover:border-neon-green/50 hover:bg-dark-secondary/60 transition-all group">
              <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">{skill.icon}</div>
              <h4 class="text-lg font-semibold text-neon-green">{skill.title}</h4>
              <p class="text-sm text-gray-400">{skill.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section with particle background -->
  <section id="services" class="section-block section-accent reveal relative py-24 overflow-hidden" data-accent="rgba(138, 43, 226, 0.2)" data-animate="up">
    <!-- Particle/dot pattern background -->
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle, rgba(0, 255, 136, 0.1) 1px, transparent 1px); background-size: 50px 50px; opacity: 0.5;"></div>
      <div class="absolute top-1/2 left-0 w-96 h-96 bg-neon-blue/20 rounded-full blur-3xl animate-orbitSmall" style="animation-delay: 0.5s;"></div>
      <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-neon-green/10 rounded-full blur-3xl animate-orbitMedium" style="animation-delay: 1s;"></div>
    </div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="reveal" data-animate="up">
        <SectionTitle title="Services" subtitle="What I Offer" />
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {portfolioData.services.map((service, idx) => (
          <div class="reveal" data-animate="up" data-delay={idx * 90}>
            <Card
              icon={service.icon}
              title={service.title}
              description={service.description}
              tags={service.tags}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Expertise Section with flowing lines background -->
  <section id="expertise" class="section-block section-accent reveal relative py-24 overflow-hidden" data-accent="rgba(0, 255, 136, 0.22)" data-animate="up">
    <div class="absolute inset-0 -z-10">
      <!-- Flowing tech lines -->
      <div class="absolute inset-0 opacity-20" style="background-image: linear-gradient(90deg, rgba(0, 255, 136, 0.2) 1px, transparent 1px), linear-gradient(0deg, rgba(0, 150, 255, 0.2) 1px, transparent 1px); background-size: 100px 100px; animation: gridFlow 40s linear infinite;"></div>
      <div class="absolute top-20 left-1/4 w-80 h-80 bg-neon-purple/15 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-20 right-1/3 w-96 h-96 bg-neon-green/15 rounded-full blur-3xl animate-float" style="animation-delay: 2s;"></div>
    </div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="reveal" data-animate="up">
        <SectionTitle title="Expertise" subtitle="Skills & Proficiencies" />
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        {portfolioData.expertise.map((exp, idx) => (
          <div class="card-glass reveal" data-animate="up" data-delay={idx * 120}>
            <h3 class="text-xl font-bold text-neon-green mb-4">{exp.title}</h3>
            <div class="w-full bg-neon-green/10 rounded-full h-2 mb-3 overflow-hidden">
              <div class="bg-gradient-to-r from-neon-green via-neon-blue to-neon-purple h-full transition-all duration-600" style={`width: ${exp.level}%`}></div>
            </div>
            <div class="flex justify-between items-center mb-3">
              <span class="text-sm font-semibold text-neon-green">{exp.level}%</span>
            </div>
            <p class="text-xs text-gray-400 leading-relaxed">{exp.skills}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Experience Section with gradient flow background -->
  <section id="experience" class="section-block section-accent reveal relative py-24 overflow-hidden" data-accent="rgba(0, 150, 255, 0.22)" data-animate="up">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-gradient-to-br from-neon-blue/10 via-dark-primary to-neon-green/10 animate-gradientShift"></div>
      <div class="absolute left-0 top-1/3 w-96 h-96 bg-neon-blue/20 rounded-full blur-3xl opacity-50"></div>
      <div class="absolute right-0 bottom-0 w-96 h-96 bg-neon-green/20 rounded-full blur-3xl opacity-50 animate-float" style="animation-delay: 1s;"></div>
    </div>

    <div class="max-w-4xl mx-auto px-6 relative z-10">
      <div class="reveal" data-animate="up">
        <SectionTitle title="Experience" subtitle="My Professional Journey" />
      </div>
      <div class="space-y-8">
        {portfolioData.experience.map((job, idx) => (
          <div class="card-glass reveal" data-animate="up" data-delay={idx * 140}>
            <div class="flex items-start justify-between mb-3">
              <div>
                <h3 class="text-xl font-bold text-neon-green">{job.title}</h3>
                <p class="text-sm text-gray-400">{job.company}</p>
              </div>
              <span class="text-sm font-semibold text-neon-blue">{job.date}</span>
            </div>
            <p class="text-gray-300 mb-4 leading-relaxed">{job.description}</p>
            <div class="flex flex-wrap gap-2">
              {job.tags.map((tag) => (
                <span class="px-2 py-1 text-xs bg-neon-green/15 text-neon-green border border-neon-green/30 rounded-full">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Projects Section with scattered particles background -->
  <section id="projects" class="section-block section-accent reveal relative py-24 overflow-hidden" data-accent="rgba(138, 43, 226, 0.22)" data-animate="up">
    <div class="absolute inset-0 -z-10">
      <!-- Scattered particles -->
      {[...Array(25)].map((_, i) => (
        <div
          class="absolute rounded-full opacity-30 animate-pulse"
          style={{
            width: Math.random() * 100 + 50 + 'px',
            height: Math.random() * 100 + 50 + 'px',
            background: `radial-gradient(circle, ${['rgba(0, 255, 136, 0.2)', 'rgba(0, 150, 255, 0.2)', 'rgba(138, 43, 226, 0.2)'][Math.floor(Math.random() * 3)]}, transparent)`,
            left: Math.random() * 100 + '%',
            top: Math.random() * 100 + '%',
            animationDelay: Math.random() * 2 + 's'
          }}
        ></div>
      ))}
    </div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="reveal" data-animate="up">
        <SectionTitle title="Projects" subtitle="Featured Work" />
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {portfolioData.projects.map((project, idx) => (
          <div class="reveal" data-animate="up" data-delay={idx * 100}>
            <Card
              title={project.title}
              description={project.description}
              tags={project.tags}
              href="#"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Education Section with minimal animated background -->
  <section id="education" class="section-block section-accent reveal relative py-24" data-accent="rgba(0, 255, 136, 0.2)" data-animate="up">
    <div class="absolute inset-0 -z-10 opacity-20">
      <div class="absolute inset-0" style="background-image: repeating-linear-gradient(45deg, rgba(0, 255, 136, 0.1) 0px, rgba(0, 255, 136, 0.1) 1px, transparent 1px, transparent 100px); animation: gridFlow 60s linear infinite;"></div>
    </div>

    <div class="max-w-4xl mx-auto px-6 relative z-10">
      <div class="reveal" data-animate="up">
        <SectionTitle title="Education" subtitle="Learning & Development" />
      </div>
      <div class="card-glass max-w-2xl mx-auto reveal" data-animate="up" data-delay="120">
        <h3 class="text-2xl font-bold text-neon-green mb-2">Bachelor of Science in Information Technology</h3>
        <p class="text-gray-300 mb-2">University of Science and Technology of Southern Philippines (USTP)</p>
        <p class="text-sm text-neon-blue font-semibold mb-4">Expected: 2026</p>
        <p class="text-gray-400">Specialization in Web Development and Internet of Things</p>
      </div>
    </div>
  </section>

  <!-- Certifications Section with radial gradient background -->
  <section id="certifications" class="section-block section-accent reveal relative py-24 overflow-hidden" data-accent="rgba(0, 150, 255, 0.2)" data-animate="up">
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-gradient-radial from-neon-green/20 to-transparent rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-0 right-0 w-80 h-80 bg-gradient-radial from-neon-blue/20 to-transparent rounded-full blur-3xl animate-float" style="animation-delay: 1.5s;"></div>
    </div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="reveal" data-animate="up">
        <SectionTitle title="Certifications" subtitle="Professional Credentials" />
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { icon: '🏆', title: 'CCNA Enterprise Networking', org: 'Cisco', date: 'May 2025' },
          { icon: '🔒', title: 'CyberOps Associate', org: 'Cisco', date: 'Dec 26, 2025' },
          { icon: '🛡️', title: 'Intro to Cybersecurity', org: 'Cisco', date: 'Sept 14, 2025' }
        ].map((cert, idx) => (
          <div class="card-glass text-center reveal" data-animate="up" data-delay={idx * 120}>
            <div class="text-5xl mb-3">{cert.icon}</div>
            <h3 class="text-lg font-semibold text-neon-green mb-1">{cert.title}</h3>
            <p class="text-sm text-gray-400 mb-2">{cert.org}</p>
            <time class="text-xs text-neon-blue font-semibold">{cert.date}</time>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Game Section -->
  <section id="game" class="section-block section-accent reveal relative py-24 overflow-hidden" data-accent="rgba(0, 255, 136, 0.22)" data-animate="up">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 opacity-30" style="background-image: radial-gradient(circle, rgba(0, 255, 136, 0.12) 1px, transparent 1px); background-size: 60px 60px;"></div>
      <div class="absolute top-12 left-1/3 w-80 h-80 bg-neon-green/10 rounded-full blur-3xl animate-float"></div>
      <div class="absolute bottom-10 right-1/4 w-96 h-96 bg-neon-blue/10 rounded-full blur-3xl animate-float" style="animation-delay: 1s;"></div>
    </div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="reveal" data-animate="up">
        <SectionTitle title="Mini Game" subtitle="Take a 30‑Second Break" />
      </div>

      <div class="game-shell reveal" data-animate="up" data-delay="120">
        <div class="game-panel">
          <canvas id="gameCanvas" width="900" height="520" aria-label="Astro Dodge game"></canvas>
        </div>
        <div class="game-ui">
          <div class="game-stats">
            <div class="stat-card">
              <span class="stat-label">Score</span>
              <span id="gameScore" class="stat-value">0</span>
            </div>
            <div class="stat-card">
              <span class="stat-label">Best</span>
              <span id="gameBest" class="stat-value">0</span>
            </div>
            <div class="stat-card">
              <span class="stat-label">Lives</span>
              <span id="gameLives" class="stat-value">3</span>
            </div>
          </div>

          <p class="game-desc">
            Pilot the neon ship, dodge incoming drones, and survive as long as you can.
          </p>
          <div class="game-controls">
            <button id="startGameBtn" class="btn-neon">Start</button>
            <button id="pauseGameBtn" class="btn-neon-outline">Pause</button>
            <button id="resetGameBtn" class="btn-neon-outline">Reset</button>
          </div>
          <ul class="game-hints">
            <li>Move: Arrow keys or WASD</li>
            <li>Boost: Shift</li>
            <li>Mobile: Drag on the canvas</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section with electric effect background -->
  <section id="contact" class="section-block section-accent reveal relative py-24 overflow-hidden" data-accent="rgba(138, 43, 226, 0.2)" data-animate="up">
    <div class="absolute inset-0 -z-10">
      <!-- Electric lines effect -->
      <div class="absolute inset-0 opacity-20" style="background: linear-gradient(90deg, transparent 0%, rgba(0, 255, 136, 0.1) 50%, transparent 100%), linear-gradient(0deg, transparent 0%, rgba(0, 150, 255, 0.1) 50%, transparent 100%); background-size: 200% 200%; animation: gradientShift 8s ease infinite;"></div>
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-neon-green/10 rounded-full blur-3xl animate-orbitSmall" style="animation-delay: 0.5s;"></div>
      <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-neon-blue/10 rounded-full blur-3xl animate-orbitMedium" style="animation-delay: 1s;"></div>
    </div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="reveal" data-animate="up">
        <SectionTitle title="Get In Touch" subtitle="Let's Connect" />
      </div>
      <div class="grid lg:grid-cols-2 gap-6 mb-10">
        {[
          { icon: '📧', label: 'Email', value: 'gaid.tristan123@gmail.com', href: 'mailto:gaid.tristan123@gmail.com' },
          { icon: '💼', label: 'LinkedIn', value: 'linkedin.com/in/tristangaid8080/', href: 'https://linkedin.com/in/tristangaid8080/' },
          { icon: '💻', label: 'GitHub', value: 'github.com/tanex08', href: 'https://github.com/tanex08' }
        ].map((link, idx) => (
          <a
            href={link.href}
            target={link.href.startsWith('http') ? '_blank' : undefined}
            rel={link.href.startsWith('http') ? 'noreferrer' : undefined}
            class="card-glass block reveal hover:scale-105 transition-transform text-center"
            data-animate="up"
            data-delay={idx * 90}
          >
            <div class="text-4xl mb-3">{link.icon}</div>
            <h4 class="text-lg font-semibold text-neon-green mb-1">{link.label}</h4>
            <p class="text-sm text-gray-400">{link.value}</p>
          </a>
        ))}
      </div>

      <div class="card-glass max-w-3xl mx-auto reveal" data-animate="up" data-delay="120">
        <form class="contact-form" action="mailto:gaid.tristan123@gmail.com" method="post">
          <div class="grid md:grid-cols-2 gap-4">
            <input type="text" name="name" placeholder="Your name" required />
            <input type="email" name="email" placeholder="Your email" required />
          </div>
          <input type="text" name="subject" placeholder="Subject" required />
          <textarea name="message" rows="5" placeholder="Your message" required></textarea>
          <button type="submit" class="btn-neon w-full">Send Message</button>
        </form>
      </div>
    </div>
  </section>

  <footer class="footer">
    <p>© 2026 Tristan Jay. All rights reserved.</p>
  </footer>
</Layout>

<style>
  :global(body) {
    --section-accent: rgba(0, 255, 136, 0.2);
  }

  .section-block {
    position: relative;
    isolation: isolate;
    scroll-margin-top: 80px;
  }

  .section-accent::after {
    content: '';
    position: absolute;
    inset: -10% 0 0 0;
    background: radial-gradient(60% 60% at 50% 0%, var(--section-accent) 0%, transparent 70%);
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s ease, transform 0.8s ease;
    pointer-events: none;
    z-index: 0;
  }

  .section-accent.is-active::after {
    opacity: 0.7;
    transform: translateY(0);
  }

  .reveal {
    opacity: 0;
    transform: translateY(28px);
    filter: blur(6px);
    transition: opacity 0.7s ease, transform 0.7s ease, filter 0.7s ease;
    will-change: opacity, transform, filter;
  }

  .reveal[data-animate='left'] {
    transform: translateX(-40px);
  }

  .reveal[data-animate='right'] {
    transform: translateX(40px);
  }

  .reveal[data-animate='fade'] {
    transform: scale(0.98);
  }

  .reveal.is-visible {
    opacity: 1;
    transform: translateX(0) translateY(0) scale(1);
    filter: none;
  }

  .animate-slideUp {
    animation: slideUp 0.6s ease-out;
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-form input,
  .contact-form textarea {
    background: rgba(20, 30, 48, 0.6);
    border: 1px solid rgba(0, 255, 136, 0.2);
    border-radius: 8px;
    padding: 1rem;
    color: var(--color-text);
    font-family: inherit;
    backdrop-filter: blur(10px);
    transition: all 0.3s;
  }

  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: rgba(0, 255, 136, 0.5);
    box-shadow: 0 0 20px rgba(0, 255, 136, 0.1);
  }

  .contact-form textarea {
    resize: vertical;
  }

  .footer {
    text-align: center;
    padding: 2rem;
    color: var(--color-text-light);
    border-top: 1px solid rgba(0, 255, 136, 0.1);
  }

  .game-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 0.8fr);
    gap: 2rem;
    align-items: start;
  }

  .game-panel {
    background: linear-gradient(135deg, rgba(0, 255, 136, 0.06), rgba(0, 150, 255, 0.04));
    border: 1px solid rgba(0, 255, 136, 0.3);
    border-radius: 16px;
    padding: 12px;
    box-shadow: 0 0 25px rgba(0, 255, 136, 0.2);
  }

  #gameCanvas {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 12px;
    background: radial-gradient(circle at 20% 20%, rgba(0, 255, 136, 0.08), transparent 60%),
      radial-gradient(circle at 80% 60%, rgba(0, 150, 255, 0.08), transparent 55%),
      #070b14;
  }

  .game-ui {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .game-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .stat-card {
    background: rgba(20, 30, 48, 0.6);
    border: 1px solid rgba(0, 255, 136, 0.2);
    border-radius: 12px;
    padding: 0.75rem;
    text-align: center;
  }

  .stat-label {
    display: block;
    font-size: 0.75rem;
    color: #b0b0b0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.35rem;
  }

  .stat-value {
    font-size: 1.4rem;
    font-weight: 700;
    color: #00ff88;
  }

  .game-desc {
    color: #b0b0b0;
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .game-controls {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .game-hints {
    list-style: none;
    padding: 0;
    margin: 0;
    color: #9aa0ad;
    font-size: 0.85rem;
    display: grid;
    gap: 0.35rem;
  }

  @media (max-width: 960px) {
    .game-shell {
      grid-template-columns: 1fr;
    }

    .game-stats {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      filter: none;
      transition: none;
    }

    .section-accent::after {
      transition: none;
      opacity: 0.4;
      transform: none;
    }
  }
</style>

<script>
  // Smooth scroll behavior is handled by CSS
  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener('click', function (e) {
      const href = this.getAttribute('href');
      if (href !== '#' && document.querySelector(href)) {
        e.preventDefault();
        document.querySelector(href).scrollIntoView({
          behavior: 'smooth',
        });
      }
    });
  });

  const revealItems = document.querySelectorAll('.reveal');
  revealItems.forEach((el) => {
    const delay = el.getAttribute('data-delay');
    if (delay) {
      el.style.transitionDelay = `${delay}ms`;
    }
  });

  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.18, rootMargin: '0px 0px -10% 0px' }
  );

  revealItems.forEach((el) => revealObserver.observe(el));

  const sections = document.querySelectorAll('.section-accent');
  const sectionObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const accent = entry.target.getAttribute('data-accent');
          if (accent) {
            document.body.style.setProperty('--section-accent', accent);
          }
          sections.forEach((section) => section.classList.remove('is-active'));
          entry.target.classList.add('is-active');
        }
      });
    },
    { threshold: 0.5 }
  );

  sections.forEach((section) => sectionObserver.observe(section));

  const canvas = document.getElementById('gameCanvas');
  if (canvas) {
    const ctx = canvas.getContext('2d');
    const scoreEl = document.getElementById('gameScore');
    const bestEl = document.getElementById('gameBest');
    const livesEl = document.getElementById('gameLives');
    const startBtn = document.getElementById('startGameBtn');
    const pauseBtn = document.getElementById('pauseGameBtn');
    const resetBtn = document.getElementById('resetGameBtn');

    const WIDTH = 900;
    const HEIGHT = 520;
    const dpr = window.devicePixelRatio || 1;
    canvas.width = WIDTH * dpr;
    canvas.height = HEIGHT * dpr;
    ctx.scale(dpr, dpr);

    const state = {
      running: false,
      paused: false,
      score: 0,
      best: Number(localStorage.getItem('astroBest') || 0),
      lives: 3,
      lastTime: 0,
      spawnTimer: 0,
      spawnInterval: 900,
      speedBoost: false,
      pointerActive: false,
      pointerX: WIDTH / 2,
      pointerY: HEIGHT / 2,
    };

    const player = {
      x: WIDTH / 2,
      y: HEIGHT * 0.75,
      r: 14,
      speed: 260,
    };

    const enemies = [];
    const particles = [];
    const keys = new Set();

    bestEl.textContent = state.best;
    livesEl.textContent = state.lives;

    function resetGame() {
      state.score = 0;
      state.lives = 3;
      state.spawnInterval = 900;
      state.spawnTimer = 0;
      enemies.length = 0;
      particles.length = 0;
      player.x = WIDTH / 2;
      player.y = HEIGHT * 0.75;
      livesEl.textContent = state.lives;
      scoreEl.textContent = state.score;
    }

    function spawnEnemy() {
      const edge = Math.floor(Math.random() * 4);
      const size = 10 + Math.random() * 16;
      let x = 0;
      let y = 0;
      if (edge === 0) {
        x = Math.random() * WIDTH;
        y = -20;
      } else if (edge === 1) {
        x = WIDTH + 20;
        y = Math.random() * HEIGHT;
      } else if (edge === 2) {
        x = Math.random() * WIDTH;
        y = HEIGHT + 20;
      } else {
        x = -20;
        y = Math.random() * HEIGHT;
      }
      enemies.push({
        x,
        y,
        r: size,
        speed: 60 + Math.random() * 100,
      });
    }

    function spawnParticles(x, y, count) {
      for (let i = 0; i < count; i += 1) {
        particles.push({
          x,
          y,
          vx: (Math.random() - 0.5) * 200,
          vy: (Math.random() - 0.5) * 200,
          life: 0.6 + Math.random() * 0.6,
        });
      }
    }

    function update(dt) {
      const speed = player.speed * (state.speedBoost ? 1.6 : 1);
      let vx = 0;
      let vy = 0;

      if (state.pointerActive) {
        const dx = state.pointerX - player.x;
        const dy = state.pointerY - player.y;
        const dist = Math.hypot(dx, dy) || 1;
        vx = (dx / dist) * speed;
        vy = (dy / dist) * speed;
        if (dist < 6) {
          vx = 0;
          vy = 0;
        }
      } else {
        if (keys.has('ArrowLeft') || keys.has('a')) vx -= speed;
        if (keys.has('ArrowRight') || keys.has('d')) vx += speed;
        if (keys.has('ArrowUp') || keys.has('w')) vy -= speed;
        if (keys.has('ArrowDown') || keys.has('s')) vy += speed;
      }

      player.x = Math.max(player.r, Math.min(WIDTH - player.r, player.x + vx * dt));
      player.y = Math.max(player.r, Math.min(HEIGHT - player.r, player.y + vy * dt));

      state.spawnTimer += dt * 1000;
      if (state.spawnTimer > state.spawnInterval) {
        state.spawnTimer = 0;
        spawnEnemy();
        state.spawnInterval = Math.max(380, state.spawnInterval - 6);
      }

      for (let i = enemies.length - 1; i >= 0; i -= 1) {
        const enemy = enemies[i];
        const dx = player.x - enemy.x;
        const dy = player.y - enemy.y;
        const dist = Math.hypot(dx, dy) || 1;
        enemy.x += (dx / dist) * enemy.speed * dt;
        enemy.y += (dy / dist) * enemy.speed * dt;

        if (dist < player.r + enemy.r) {
          enemies.splice(i, 1);
          state.lives -= 1;
          livesEl.textContent = state.lives;
          spawnParticles(player.x, player.y, 16);
          if (state.lives <= 0) {
            state.running = false;
            state.paused = false;
            pauseBtn.textContent = 'Pause';
          }
        }
      }

      for (let i = particles.length - 1; i >= 0; i -= 1) {
        const p = particles[i];
        p.life -= dt;
        p.x += p.vx * dt;
        p.y += p.vy * dt;
        if (p.life <= 0) particles.splice(i, 1);
      }

      if (state.running) {
        state.score += Math.floor(dt * 120);
        scoreEl.textContent = state.score;
        if (state.score > state.best) {
          state.best = state.score;
          bestEl.textContent = state.best;
          localStorage.setItem('astroBest', state.best);
        }
      }
    }

    function draw() {
      ctx.clearRect(0, 0, WIDTH, HEIGHT);
      ctx.save();

      const gradient = ctx.createRadialGradient(player.x, player.y, 0, player.x, player.y, 220);
      gradient.addColorStop(0, 'rgba(0, 255, 136, 0.12)');
      gradient.addColorStop(1, 'rgba(0, 0, 0, 0)');
      ctx.fillStyle = gradient;
      ctx.fillRect(0, 0, WIDTH, HEIGHT);

      enemies.forEach((enemy) => {
        ctx.beginPath();
        ctx.fillStyle = 'rgba(0, 150, 255, 0.6)';
        ctx.arc(enemy.x, enemy.y, enemy.r, 0, Math.PI * 2);
        ctx.fill();
      });

      particles.forEach((p) => {
        ctx.beginPath();
        ctx.fillStyle = 'rgba(0, 255, 136, 0.7)';
        ctx.arc(p.x, p.y, 2.2, 0, Math.PI * 2);
        ctx.fill();
      });

      ctx.beginPath();
      ctx.fillStyle = 'rgba(0, 255, 136, 0.9)';
      ctx.moveTo(player.x, player.y - player.r);
      ctx.lineTo(player.x - player.r, player.y + player.r);
      ctx.lineTo(player.x + player.r, player.y + player.r);
      ctx.closePath();
      ctx.fill();

      ctx.restore();
    }

    function loop(timestamp) {
      if (!state.lastTime) state.lastTime = timestamp;
      const dt = Math.min(0.033, (timestamp - state.lastTime) / 1000);
      state.lastTime = timestamp;

      if (state.running && !state.paused) {
        update(dt);
      }
      draw();
      requestAnimationFrame(loop);
    }

    function startGame() {
      if (!state.running) {
        resetGame();
        state.running = true;
      }
    }

    function togglePause() {
      if (!state.running) return;
      state.paused = !state.paused;
      pauseBtn.textContent = state.paused ? 'Resume' : 'Pause';
    }

    function stopGame() {
      state.running = false;
      state.paused = false;
      pauseBtn.textContent = 'Pause';
      resetGame();
    }

    startBtn?.addEventListener('click', startGame);
    pauseBtn?.addEventListener('click', togglePause);
    resetBtn?.addEventListener('click', stopGame);

    window.addEventListener('keydown', (e) => {
      if (['ArrowLeft', 'ArrowRight', 'ArrowUp', 'ArrowDown'].includes(e.key)) e.preventDefault();
      if (e.key === 'Shift') state.speedBoost = true;
      keys.add(e.key.toLowerCase());
      if (e.key === ' ') {
        startGame();
      }
    });

    window.addEventListener('keyup', (e) => {
      if (e.key === 'Shift') state.speedBoost = false;
      keys.delete(e.key.toLowerCase());
    });

    canvas.addEventListener('pointerdown', (e) => {
      state.pointerActive = true;
      const rect = canvas.getBoundingClientRect();
      state.pointerX = ((e.clientX - rect.left) / rect.width) * WIDTH;
      state.pointerY = ((e.clientY - rect.top) / rect.height) * HEIGHT;
      startGame();
    });

    canvas.addEventListener('pointermove', (e) => {
      if (!state.pointerActive) return;
      const rect = canvas.getBoundingClientRect();
      state.pointerX = ((e.clientX - rect.left) / rect.width) * WIDTH;
      state.pointerY = ((e.clientY - rect.top) / rect.height) * HEIGHT;
    });

    window.addEventListener('pointerup', () => {
      state.pointerActive = false;
    });

    requestAnimationFrame(loop);
  }
</script>
